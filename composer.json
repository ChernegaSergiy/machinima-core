{
    "name": "morfeditorial/machinima-core",
    "description": "The Core CMS bundle for the Machinima platform.",
    "type": "symfony-bundle",
    "license": "LicenseRef-CSSM-Unlimited-2.0",
    "authors": [
        {
            "name": "Serhii Cherneha",
            "email": "chernegasergiy3@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "dicebear/core": "^10.3",
        "dicebear/styles": "^10.2",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6",
        "phpdocumentor/reflection-docblock": "^6.0",
        "phpstan/phpdoc-parser": "^2.3",
        "symfony/asset": "^8.1",
        "symfony/console": "8.1.*",
        "symfony/framework-bundle": "8.1.*",
        "symfony/mercure-bundle": "*",
        "symfony/messenger": "8.1.*",
        "symfony/property-access": "8.1.*",
        "symfony/property-info": "8.1.*",
        "symfony/security-bundle": "8.1.*",
        "symfony/serializer": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/workflow": "8.1.*",
        "symfony/yaml": "8.1.*",
        "yzalis/identicon": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "symfony/maker-bundle": "^1.67"
    },
    "autoload": {
        "psr-4": {
            "Morfeditorial\\MachinimaCoreBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Morfeditorial\\MachinimaCoreBundle\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
