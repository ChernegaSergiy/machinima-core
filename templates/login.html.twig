{% extends 'base.html.twig' %}

{% block body %}
<div class="w-full max-w-600 mx-auto p-4 pb-0 min-h-screen flex items-center justify-center">
    <div class="text-center py-8 px-4 mb-8 bg-surface rounded border-2 border-border shadow-brutal w-full">
        <div class="w-22 h-22 mx-auto mb-6 rounded bg-surface flex items-center justify-center text-primary border-2 border-border shadow-brutal overflow-hidden shrink-0">
            <i data-lucide="log-in" class="w-10 h-10 stroke-1-5"></i>
        </div>
        <h1 class="text-[26px] font-bold mb-3 m-0 font-unbounded tracking-tight uppercase">Увійти</h1>
        <p class="text-base text-primary mb-6 leading-relaxed font-semibold">
            Оберіть спосіб входу
        </p>

        <div class="flex flex-col gap-3">
            {% for provider in providers %}
                {% if provider.login_url|default(null) %}
                    <a href="{{ provider.login_url }}"
                       class="bg-border text-surface py-3 px-6 rounded font-bold text-[14px] uppercase flex items-center justify-center cursor-pointer border-2 border-border shadow-btn transition-all font-unbounded active:translate-brutal-sm active:shadow-xs w-full">
                        <i data-lucide="{{ provider.icon }}" class="mr-2 w-[18px] h-[18px] stroke-2-5"></i>
                        {{ provider.label }}
                    </a>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
