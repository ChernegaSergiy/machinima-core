{% extends 'base.html.twig' %}

{% block body %}
<div class="w-full max-w-600 mx-auto p-4 pb-0 min-h-screen">
    <div class="sticky top-0 left-0 right-0 bg-surface border-b-2 border-border flex items-center p-4 z-90 hide-on-tma mb-4 -mx-4 -mt-4">
        <a href="{{ path('app_profile') }}" class="font-bold flex items-center uppercase font-unbounded tracking-tight no-underline text-inherit cursor-pointer active:opacity-80">
            <i data-lucide="arrow-left" class="mr-2 w-6 h-6 stroke-2-5"></i> Назад
        </a>
    </div>

    <div class="flex items-center justify-between mb-6 pb-3 border-b-2 border-border">
        <h1 class="text-3xl font-bold m-0 font-unbounded tracking-tight uppercase">Прив'язані акаунти</h1>
    </div>

    {% if identities|length > 0 %}
        <h2 class="text-xl font-bold mb-5 text-primary border-b-2 border-border pb-2 font-unbounded tracking-tight uppercase">Прив'язані</h2>
        {% for identity in identities %}
            <div class="flex items-center p-4 bg-surface rounded border-2 border-border mb-4 transition-all shadow-brutal">
                <div class="w-12 h-12 rounded bg-surface flex items-center justify-center text-primary mr-4 shrink-0 border-2 border-border shadow-brutal-sm">
                    <i data-lucide="{{ identity.providerName }}" class="w-6 h-6 stroke-2"></i>
                </div>
                <div class="flex-1">
                    <div class="flex items-center text-lg font-bold mb-1 font-unbounded tracking-tight uppercase">{{ identity.providerName }}</div>
                    <div class="text-[14px] text-primary mb-1 leading-normal font-semibold">ID: {{ identity.providerId }}</div>
                </div>
            </div>
        {% endfor %}
    {% endif %}

    {% if available_providers|length > 0 and link_route_exists %}
        <h2 class="text-xl font-bold mb-5 text-primary border-b-2 border-border pb-2 font-unbounded tracking-tight uppercase mt-6">Додати акаунт</h2>
        {% for provider in available_providers %}
            <a href="{{ path('popular_oidcs_link', {provider: provider.name}) }}"
               class="flex items-center p-4 bg-surface rounded border-2 border-border mb-4 cursor-pointer transition-all shadow-brutal active:translate-brutal active:shadow-none no-underline text-inherit">
                <div class="w-12 h-12 rounded bg-surface flex items-center justify-center text-primary mr-4 shrink-0 border-2 border-border shadow-brutal-sm">
                    <i data-lucide="{{ provider.icon }}" class="w-6 h-6 stroke-2"></i>
                </div>
                <div class="flex-1">
                    <div class="flex items-center text-lg font-bold mb-1 font-unbounded tracking-tight uppercase">{{ provider.label }}</div>
                    <div class="text-[14px] text-primary mb-1 leading-normal font-semibold">Прив'язати {{ provider.label }}</div>
                </div>
                <i data-lucide="plus-circle" class="text-muted w-6 h-6 stroke-2"></i>
            </a>
        {% endfor %}
    {% endif %}

    {% if identities|length == 0 and available_providers|length == 0 %}
        <div class="text-center py-8 px-4 mb-8 bg-surface rounded border-2 border-border shadow-brutal">
            <div class="w-22 h-22 mx-auto mb-6 rounded bg-surface flex items-center justify-center text-primary border-2 border-border shadow-brutal overflow-hidden shrink-0">
                <i data-lucide="link" class="w-10 h-10 stroke-1-5"></i>
            </div>
            <p class="text-base text-primary mb-6 leading-relaxed font-semibold">
                Немає доступних способів для прив'язки
            </p>
        </div>
    {% endif %}
</div>
{% endblock %}
