{% extends 'base.html.twig' %}

{% block body %}
<div class="container">
    <div class="page-header-flex">
        <h1 class="page-title">Профіль</h1>
    </div>

    <!-- Personal Info Card -->
    <div class="profile-header">
        <div class="profile-avatar">
            <img id="profile-avatar-img" src="" alt="Avatar" style="width: 100%; height: 100%; border-radius: inherit; object-fit: cover; display: none;">
            <i id="profile-avatar-placeholder" data-lucide="user" style="width: 40px; height: 40px; stroke-width: 1.5px;"></i>
        </div>
        <h2 id="profile-name" class="profile-name">Завантаження...</h2>
        <div id="profile-username" class="profile-bio">@username</div>
        
        <span class="badge">
            {% if is_granted('ROLE_ADMIN') %}
                Адміністратор
            {% elseif is_granted('ROLE_MODERATOR') %}
                Модератор
            {% elseif is_granted('ROLE_CREATOR') %}
                Творець
            {% else %}
                Користувач
            {% endif %}
        </span>
    </div>

    <!-- Stats -->
    <h2 class="section-title">Статистика</h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
        <div class="card" style="margin-bottom: 0; padding: 16px; text-align: center; display: flex; flex-direction: column; justify-content: center;">
            <div class="list-title" style="justify-content: center; font-size: 24px; margin-bottom: 4px;">0</div>
            <div class="list-meta">Підписок</div>
        </div>
        <div class="card" style="margin-bottom: 0; padding: 16px; text-align: center; display: flex; flex-direction: column; justify-content: center;">
            <div class="list-title" style="justify-content: center; font-size: 24px; margin-bottom: 4px;">0</div>
            <div class="list-meta">Вподобань</div>
        </div>
    </div>

    <!-- Actions -->
    <h2 class="section-title">Налаштування</h2>
    
    <div class="list-item">
        <div class="list-icon">
            <i data-lucide="shield-check"></i>
        </div>
        <div class="list-content">
            <div class="list-title">Акаунт створено</div>
            <div class="list-desc">Невідомо</div>
        </div>
    </div>

    <div class="list-item">
        <div class="list-icon">
            <i data-lucide="edit-3"></i>
        </div>
        <div class="list-content">
            <div class="list-title">Публічна сторінка</div>
            <div class="list-desc">Немає прив'язаної сторінки</div>
        </div>
    </div>

</div>

<script>
(function() {
    if (window.Telegram && window.Telegram.WebApp && window.Telegram.WebApp.initDataUnsafe && window.Telegram.WebApp.initDataUnsafe.user) {
        const user = window.Telegram.WebApp.initDataUnsafe.user;
        const nameEl = document.getElementById('profile-name');
        const usernameEl = document.getElementById('profile-username');
        const avatarImgEl = document.getElementById('profile-avatar-img');
        const avatarPlaceholderEl = document.getElementById('profile-avatar-placeholder');

        if (nameEl) nameEl.textContent = user.first_name + (user.last_name ? ' ' + user.last_name : '');
        if (usernameEl) {
            if (user.username) {
                usernameEl.textContent = '@' + user.username;
            } else {
                usernameEl.style.display = 'none';
            }
        }
        if (avatarImgEl && user.photo_url) {
            avatarImgEl.src = user.photo_url;
            avatarImgEl.style.display = 'block';
            if (avatarPlaceholderEl) avatarPlaceholderEl.style.display = 'none';
        }
    }
})();
</script>
{% endblock %}
