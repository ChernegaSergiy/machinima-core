{% extends 'base.html.twig' %}

{% block body %}
<div class="container" style="padding-top: 16px;">
    <div class="page-header-flex">
        <h1 class="page-title">Профіль</h1>
    </div>

    <!-- Personal Info Card -->
    <div class="card" style="margin-top: 16px; padding: 24px; text-align: center; border-radius: 16px;">
        <div style="margin-bottom: 16px;">
            <img id="profile-avatar" src="" alt="Avatar" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; background: var(--surface); display: inline-block;">
        </div>
        <h2 id="profile-name" style="font-size: 24px; font-weight: 700; font-family: 'Unbounded', sans-serif; margin: 0 0 4px 0;">Завантаження...</h2>
        <p id="profile-username" style="color: var(--text-secondary); margin: 0; font-size: 14px;">@username</p>
        
        <div style="margin-top: 16px; display: inline-block; background: var(--surface); padding: 4px 12px; border-radius: 16px; font-size: 12px; font-weight: 600; color: var(--primary);">
            {% if is_granted('ROLE_CREATOR') %}
                Кріейтор
            {% else %}
                Користувач
            {% endif %}
        </div>
    </div>

    <!-- Stats Grid -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 12px;">
        <div class="card" style="padding: 16px; text-align: center; border-radius: 12px;">
            <div style="font-size: 24px; font-weight: 700; font-family: 'Unbounded', sans-serif; color: var(--text);">0</div>
            <div style="font-size: 12px; color: var(--text-secondary); margin-top: 4px;">Підписок</div>
        </div>
        <div class="card" style="padding: 16px; text-align: center; border-radius: 12px;">
            <div style="font-size: 24px; font-weight: 700; font-family: 'Unbounded', sans-serif; color: var(--text);">0</div>
            <div style="font-size: 12px; color: var(--text-secondary); margin-top: 4px;">Вподобань</div>
        </div>
    </div>

    <!-- Actions -->
    <div style="margin-top: 24px;">
        <h3 style="font-size: 16px; font-weight: 600; margin-bottom: 12px;">Налаштування</h3>
        <div class="card" style="border-radius: 12px;">
            <div class="list-item" style="border-bottom: 1px solid var(--border);">
                <div class="list-icon" style="background: rgba(10, 132, 255, 0.1); color: var(--primary);">
                    <i data-lucide="shield-check"></i>
                </div>
                <div class="list-content">
                    <h4 style="margin: 0; font-size: 15px; font-weight: 500;">Акаунт створено</h4>
                    <p style="margin: 4px 0 0 0; font-size: 13px; color: var(--text-secondary);">Невідомо</p>
                </div>
            </div>
            <div class="list-item">
                <div class="list-icon" style="background: rgba(255, 149, 0, 0.1); color: #FF9500;">
                    <i data-lucide="edit-3"></i>
                </div>
                <div class="list-content">
                    <h4 style="margin: 0; font-size: 15px; font-weight: 500;">Публічна сторінка</h4>
                    <p style="margin: 4px 0 0 0; font-size: 13px; color: var(--text-secondary);">Немає прив'язаної сторінки</p>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
(function() {
    if (window.Telegram && window.Telegram.WebApp && window.Telegram.WebApp.initDataUnsafe && window.Telegram.WebApp.initDataUnsafe.user) {
        const user = window.Telegram.WebApp.initDataUnsafe.user;
        const nameEl = document.getElementById('profile-name');
        const usernameEl = document.getElementById('profile-username');
        const avatarEl = document.getElementById('profile-avatar');

        if (nameEl) nameEl.textContent = user.first_name + (user.last_name ? ' ' + user.last_name : '');
        if (usernameEl) {
            if (user.username) {
                usernameEl.textContent = '@' + user.username;
            } else {
                usernameEl.style.display = 'none';
            }
        }
        if (avatarEl) {
            if (user.photo_url) {
                avatarEl.src = user.photo_url;
            } else {
                avatarEl.style.display = 'none';
            }
        }
    }
})();
</script>
{% endblock %}
