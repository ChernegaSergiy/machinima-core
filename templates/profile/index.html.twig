{% extends 'base.html.twig' %}

{% block body %}
<div class="w-full max-w-600 mx-auto p-4">
    {% if app.request.query.get('back') %}
    <div class="sticky top-0 left-0 right-0 bg-surface border-b-2 border-border flex items-center p-4 z-90 hide-on-tma mb-4 -mx-4 -mt-4">
        <a href="#" onclick="window.history.back(); return false;" class="font-bold flex items-center uppercase font-unbounded tracking-tight no-underline text-inherit cursor-pointer active:opacity-80"><i data-lucide="arrow-left" class="mr-2 w-6 h-6 stroke-2-5"></i> Назад</a>
    </div>
    {% endif %}
    
    <div class="flex items-center justify-between mb-6 pb-3 border-b-2 border-border">
        <h1 class="text-3xl font-bold m-0 font-unbounded tracking-tight uppercase">Профіль</h1>
    </div>

    <!-- Personal Info Card -->
    <div class="text-center py-8 px-4 mb-8 bg-surface rounded border-2 border-border shadow-brutal">
        <div class="w-22 h-22 mx-auto mb-5 rounded bg-surface flex items-center justify-center text-primary border-2 border-border shadow-brutal overflow-hidden shrink-0">
            <img id="profile-avatar-img" src="" alt="Avatar" class="w-full h-full object-cover hidden">
            <i id="profile-avatar-placeholder" data-lucide="user" class="w-10 h-10 stroke-1-5 shrink-0"></i>
        </div>
        <h2 id="profile-name" class="text-[26px] font-bold mb-3 m-0 font-unbounded tracking-tight uppercase">Завантаження...</h2>
        <div id="profile-username" class="text-base text-primary mb-6 leading-relaxed font-semibold">@username</div>
        
        <span class="bg-border text-surface py-0-5 px-2 rounded text-xs font-bold uppercase font-unbounded inline-block">
            {% if is_granted('ROLE_ADMIN') %}
                Адміністратор
            {% elseif is_granted('ROLE_MODERATOR') %}
                Модератор
            {% elseif is_granted('ROLE_CREATOR') %}
                Творець
            {% else %}
                Користувач
            {% endif %}
        </span>
    </div>

    <!-- Stats -->
    <h2 class="text-xl font-bold mb-5 text-primary border-b-2 border-border pb-2 font-unbounded tracking-tight uppercase">Статистика</h2>
    <div class="grid grid-cols-2 gap-4 mb-6">
        <a href="{{ path('app_profile_following') }}" data-skeleton="following" class="bg-surface border-2 border-border rounded p-4 text-center flex flex-col justify-center mb-0 cursor-pointer transition-all shadow-brutal active:translate-brutal active:shadow-none no-underline text-inherit">
            <div class="flex justify-center items-center text-2xl font-bold mb-1 font-unbounded tracking-tight uppercase">{{ followingCount }}</div>
            <div class="text-[12px] text-muted font-bold uppercase">Підписок</div>
        </a>
        <a href="{{ path('app_profile_likes') }}" data-skeleton="likes" class="bg-surface border-2 border-border rounded p-4 text-center flex flex-col justify-center mb-0 cursor-pointer transition-all shadow-brutal active:translate-brutal active:shadow-none no-underline text-inherit">
            <div class="flex justify-center items-center text-2xl font-bold mb-1 font-unbounded tracking-tight uppercase">{{ likesCount }}</div>
            <div class="text-[12px] text-muted font-bold uppercase">Вподобань</div>
        </a>
    </div>

    <!-- Actions -->
    <h2 class="text-xl font-bold mb-5 text-primary border-b-2 border-border pb-2 font-unbounded tracking-tight uppercase">Налаштування</h2>
    
    <div class="flex items-center p-4 bg-surface rounded border-2 border-border mb-4 transition-all shadow-brutal">
        <div class="w-12 h-12 rounded bg-surface flex items-center justify-center text-primary mr-4 shrink-0 border-2 border-border shadow-brutal-sm">
            <i data-lucide="shield-check" class="w-6 h-6 stroke-2"></i>
        </div>
        <div class="flex-1">
            <div class="flex items-center text-lg font-bold mb-1 font-unbounded tracking-tight uppercase">Акаунт створено</div>
            <div class="text-[14px] text-primary mb-1 leading-normal font-semibold">{{ userData.createdAt ? userData.createdAt|date('d.m.Y') : 'Невідомо' }}</div>
        </div>
    </div>

    {% if myAuthorPage %}
        <a href="{{ path('app_author', {id: myAuthorPage.id}) }}" data-skeleton="author" class="flex items-center p-4 bg-surface rounded border-2 border-border mb-4 cursor-pointer transition-all shadow-brutal active:translate-brutal active:shadow-none no-underline text-inherit">
            <div class="w-12 h-12 rounded bg-surface flex items-center justify-center text-primary mr-4 shrink-0 border-2 border-border shadow-brutal-sm">
                <i data-lucide="user-check" class="w-6 h-6 stroke-2"></i>
            </div>
            <div class="flex-1">
                <div class="flex items-center text-lg font-bold mb-1 font-unbounded tracking-tight uppercase">Публічна сторінка</div>
                <div class="text-[14px] text-primary mb-1 leading-normal font-semibold">Моя сторінка</div>
            </div>
            <i data-lucide="chevron-right" class="text-muted w-6 h-6 stroke-2"></i>
        </a>
    {% else %}
        <div class="flex items-center p-4 bg-surface rounded border-2 border-border mb-4 transition-all shadow-brutal">
            <div class="w-12 h-12 rounded bg-surface flex items-center justify-center text-primary mr-4 shrink-0 border-2 border-border shadow-brutal-sm">
                <i data-lucide="edit-3" class="w-6 h-6 stroke-2"></i>
            </div>
            <div class="flex-1">
                <div class="flex items-center text-lg font-bold mb-1 font-unbounded tracking-tight uppercase">Публічна сторінка</div>
                <div class="text-[14px] text-primary mb-1 leading-normal font-semibold">Немає прив'язаної сторінки</div>
            </div>
        </div>
    {% endif %}

</div>

<script>
(function() {
    const tgUser = window.__PLATFORM__?.initDataUnsafe?.user || window.Telegram?.WebApp?.initDataUnsafe?.user;
    if (tgUser) {
        const user = tgUser;
        const nameEl = document.getElementById('profile-name');
        const usernameEl = document.getElementById('profile-username');
        const avatarImgEl = document.getElementById('profile-avatar-img');
        const avatarPlaceholderEl = document.getElementById('profile-avatar-placeholder');

        if (nameEl) nameEl.textContent = user.first_name + (user.last_name ? ' ' + user.last_name : '');
        if (usernameEl) {
            if (user.username) {
                usernameEl.textContent = '@' + user.username;
            } else {
                usernameEl.style.display = 'none';
            }
        }
        if (avatarImgEl && user.photo_url) {
            avatarImgEl.src = user.photo_url;
            avatarImgEl.style.display = 'block';
            if (avatarPlaceholderEl) avatarPlaceholderEl.style.display = 'none';
        }
    }
})();
</script>
{% endblock %}
