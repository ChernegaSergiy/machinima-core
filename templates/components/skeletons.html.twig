<template id="skeleton-categories">
    <div class="w-full max-w-600 mx-auto p-4 pb-30">
        <div class="flex items-center justify-between mb-6 pb-3 border-b-2 border-border">
            <h1 class="text-3xl font-bold m-0 font-unbounded tracking-tight uppercase">Категорії</h1>
        </div>
        {% for i in 1..5 %}
            <div class="flex items-center p-4 bg-surface rounded border-2 border-border mb-4 shadow-brutal pointer-events-none">
                <div class="w-12 h-12 rounded bg-surface border-2 border-border shadow-brutal-sm mr-4 shrink-0 animate-shimmer"></div>
                <div class="flex-1">
                    <div class="animate-shimmer" style="width: 50%; height: 16px; margin: 0; border-radius: 4px;"></div>
                </div>
                <div class="animate-shimmer" style="width: 20px; height: 20px; border-radius: 4px; opacity: 0.3;"></div>
            </div>
        {% endfor %}
    </div>
</template>

<template id="skeleton-authors">
    <div class="w-full max-w-600 mx-auto p-4 pb-30">
        <div class="flex items-center justify-between mb-6 pb-3 border-b-2 border-border">
            <h1 class="text-3xl font-bold m-0 font-unbounded tracking-tight uppercase">Автори</h1>
        </div>
