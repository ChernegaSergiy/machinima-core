                <div class="flex-1">
                    <div class="animate-shimmer" style="width: 45%; height: 16px; margin-bottom: 6px; border-radius: 4px;"></div>
                    <div class="animate-shimmer" style="width: 70%; height: 14px; margin: 0; border-radius: 4px;"></div>
                </div>
                <div class="animate-shimmer" style="width: 20px; height: 20px; border-radius: 4px; opacity: 0.3;"></div>
            </div>
        {% endfor %}
    </div>
</template>

<template id="skeleton-post">
    <div class="w-full max-w-600 mx-auto p-4 pb-30">
        <div class="bg-surface border-2 border-border rounded p-4 mb-6 shadow-brutal pointer-events-none">
            <div class="flex items-center mb-4">
                <div class="w-11 h-11 rounded bg-surface border-2 border-border shadow-brutal-sm mr-3 shrink-0 animate-shimmer"></div>
                <div class="flex-1">
                    <div class="animate-shimmer" style="width: 40%; height: 16px; margin-bottom: 4px; border-radius: 4px;"></div>
                    <div class="animate-shimmer" style="width: 25%; height: 10px; margin: 0; border-radius: 4px;"></div>
                </div>
            </div>
            <div class="animate-shimmer" style="width: 85%; height: 28px; margin-bottom: 20px; border-radius: 4px;"></div>
            <div class="mb-6">
                <div class="animate-shimmer" style="width: 100%; height: 16px; margin-bottom: 8px; border-radius: 4px;"></div>
                <div class="animate-shimmer" style="width: 100%; height: 16px; margin-bottom: 8px; border-radius: 4px;"></div>
                <div class="animate-shimmer" style="width: 80%; height: 16px; border-radius: 4px;"></div>
            </div>
            <div class="w-full aspect-video bg-surface border-2 border-border rounded animate-shimmer"></div>
            <div class="flex items-center gap-3 mt-4 pt-4 border-t-2 border-border">
                <div class="animate-shimmer border-2 border-border rounded h-10 shadow-brutal-sm" style="width: 60px;"></div>
                <div class="animate-shimmer border-2 border-border rounded h-10 shadow-brutal-sm" style="width: 44px;"></div>
                <div class="animate-shimmer border-2 border-border rounded h-10 shadow-brutal-sm ml-auto" style="width: 50px;"></div>
            </div>
        </div>
        <h2 class="text-xl font-bold mb-5 text-primary border-b-2 border-border pb-2 font-unbounded tracking-tight uppercase">
            <div class="animate-shimmer" style="width: 120px; height: 20px; margin: 0; display: inline-block; vertical-align: middle; border-radius: 4px;"></div>
        </h2>
        <div id="comments-list">
            {% for i in 1..2 %}
                <div class="bg-surface border-2 border-border rounded p-4 mb-4 shadow-brutal pointer-events-none">
                    <div class="flex items-center mb-3">
                        <div class="w-10 h-10 rounded bg-surface border-2 border-border shadow-brutal-sm mr-3 shrink-0 animate-shimmer"></div>
                        <div class="flex-1">
                            <div class="animate-shimmer" style="width: 30%; height: 14px; margin-bottom: 4px; border-radius: 4px;"></div>
                            <div class="animate-shimmer" style="width: 20%; height: 10px; margin: 0; border-radius: 4px;"></div>
                        </div>
                    </div>
                    <div class="animate-shimmer" style="width: 100%; height: 14px; margin-bottom: 6px; border-radius: 4px;"></div>
                    <div class="animate-shimmer" style="width: 70%; height: 14px; border-radius: 4px;"></div>
                    <div class="mt-3">
                        <div class="animate-shimmer border-2 border-border rounded h-8 shadow-brutal-xs" style="width: 120px;"></div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</template>

