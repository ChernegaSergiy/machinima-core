<!doctype html>
<html lang="uk">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, shrink-to-fit=no" />
    <title>{% block title %}Morf TMA{% endblock %}</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link rel="stylesheet" href="/css/index.css?v={{ random() }}">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
    {% block body %}{% endblock %}

    {% block tabbar %}
    {% set current_route = app.request.attributes.get('_route') %}
    <nav class="bottom-tabbar">
        <a href="{{ path('app_index') }}" class="tab-item {% if current_route == 'app_index' %}active{% endif %}">
            <i data-lucide="play-square"></i>
            <span>Стрічка</span>
        </a>
        <a href="{{ path('app_categories') }}" class="tab-item {% if current_route == 'app_categories' %}active{% endif %}">
            <i data-lucide="layout-grid"></i>
            <span>Категорії</span>
        </a>
        <a href="{{ path('app_authors') }}" class="tab-item {% if current_route == 'app_authors' %}active{% endif %}">
            <i data-lucide="users"></i>
            <span>Автори</span>
        </a>
        <a href="{{ path('app_notifications') }}" class="tab-item {% if current_route == 'app_notifications' %}active{% endif %}">
            <i data-lucide="bell"></i>
            <span>Сповіщ.</span>
        </a>
    </nav>
    {% endblock %}

    <script type="module" src="https://unpkg.com/@hotwired/turbo@8.0.4/dist/turbo.es2017-esm.js"></script>
    <script>
        function initApp() {
            const tg = window.Telegram?.WebApp;
            if (tg) {
                tg.ready();
                tg.expand();
                
                if (tg.initData) {
                    const currentRoute = '{{ app.request.attributes.get("_route") }}';
                    const rootRoutes = ['app_index', 'app_categories', 'app_authors', 'app_notifications'];
                    if (!rootRoutes.includes(currentRoute)) {
                        tg.BackButton.show();
                        tg.BackButton.onClick(() => window.history.back());
                    } else {
                        tg.BackButton.hide();
                    }
                }
            }
            if (typeof lucide !== 'undefined') lucide.createIcons();
            
            const initData = window.Telegram?.WebApp?.initData;
            if (initData) {
                document.querySelectorAll('a').forEach(a => {
                    if (a.href && a.href.startsWith(window.location.origin)) {
                        try {
                            const url = new URL(a.href);
                            if (!url.searchParams.has('initData')) {
                                url.searchParams.set('initData', initData);
                                a.href = url.toString();
                            }
                        } catch (e) {}
                    }
                });
            }
        }
        document.addEventListener('turbo:load', initApp);
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initApp);
        } else {
            initApp();
        }
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>
