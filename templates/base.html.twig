<!doctype html>
<html lang="uk">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, shrink-to-fit=no" />
    <title>Тільки через Telegram</title>
    <meta name="turbo-cache-control" content="no-cache" />
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script>
        if (window.Telegram?.WebApp?.initData) {
            document.title = "Morf TMA";
        }
        
        // STRICT ACCESS CONTROL
        if (!window.Telegram || !window.Telegram.WebApp || !window.Telegram.WebApp.initData) {
            document.documentElement.style.visibility = 'hidden';
            
            document.addEventListener('DOMContentLoaded', function() {
                document.documentElement.style.visibility = '';
                document.body.innerHTML = `
                <div class="w-full max-w-600 mx-auto p-4 pb-0 min-h-screen flex items-center justify-center">
                    <div class="text-center py-8 px-4 mb-8 bg-surface rounded border-2 border-border shadow-brutal w-full">
                        <div class="w-22 h-22 mx-auto mb-6 rounded bg-surface flex items-center justify-center text-primary border-2 border-border shadow-brutal overflow-hidden shrink-0">
                            <i data-lucide="lock" class="w-10 h-10 stroke-1-5"></i>
                        </div>
                        <h1 class="text-[26px] font-bold mb-3 m-0 font-unbounded tracking-tight uppercase">Тільки через Telegram</h1>
                        <p class="text-base text-primary mb-6 leading-relaxed font-semibold">
                            Цей застосунок розроблено спеціально для використання всередині Telegram.
                        </p>
                        <a href="https://t.me/{{ bot_username }}" class="bg-border text-surface py-3 px-6 rounded font-bold text-[14px] uppercase flex items-center justify-center cursor-pointer border-2 border-border shadow-btn transition-all font-unbounded active:translate-brutal-sm active:shadow-xs w-full">
                            <i data-lucide="external-link" class="mr-2 w-[18px] h-[18px] stroke-2-5"></i>
                            Відкрити бота
                        </a>
                    </div>
                </div>`;
                if (typeof lucide !== 'undefined') lucide.createIcons();
            });
        } else {
            const tg = window.Telegram.WebApp;
            window.currentUserId = tg.initDataUnsafe?.user?.id;
            const updateTheme = () => {
                document.documentElement.style.setProperty('--shimmer-base', tg.colorScheme === 'dark' ? '255, 255, 255' : '0, 0, 0');
            };
            updateTheme();
            tg.onEvent('themeChanged', updateTheme);

            let cookieStr = "tma_init_data=" + encodeURIComponent(tg.initData) + "; path=/; max-age=86400;";
            if (window.location.protocol === 'https:') cookieStr += " SameSite=None; Secure;";
            document.cookie = cookieStr;

            // Fallback for strict browsers (like WebKitGTK on Linux/Fedora) that drop JS cookies
            document.addEventListener('click', function(e) {
                const link = e.target.closest('a');
                if (link && link.href && link.href.startsWith(window.location.origin) && window.Telegram?.WebApp?.initData) {
                    try {
                        const url = new URL(link.href);
                        if (!url.searchParams.has('initData')) {
                            url.searchParams.set('initData', window.Telegram.WebApp.initData);
                            link.href = url.toString();
                        }
                    } catch(err) {}
                }
            });
        }
    </script>
    <link rel="stylesheet" href="/css/index.css?v={{ random() }}">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body data-route="{{ app.request.attributes.get('_route') }}">
    <main id="main-content" class="turbo-transition">
        {% block body %}{% endblock %}
    </main>

    {% block tabbar %}
    {% set current_route = app.request.attributes.get('_route') %}
    <nav class="fixed bottom-0 left-0 right-0 bg-surface border-t-2 border-border flex safe-pb z-100 max-w-600 mx-auto">
        {% set active_classes = 'opacity-100 font-extrabold bg-black-5 border-t-3 border-border -mt-0-5' %}
        {% set default_classes = 'opacity-60 font-bold' %}
        
        <a href="{{ path('app_index') }}" data-skeleton="feed" class="flex-1 flex flex-col items-center justify-center py-4 text-primary text-xs transition-all uppercase font-unbounded active:bg-black-10 {% if current_route == 'app_index' %}{{ active_classes }}{% else %}{{ default_classes }}{% endif %}">
            <i data-lucide="play-square" class="mb-1 w-6 h-6 stroke-2-5"></i>
            <span>Стрічка</span>
        </a>
        <a href="{{ path('app_categories') }}" data-skeleton="categories" class="flex-1 flex flex-col items-center justify-center py-4 text-primary text-xs transition-all uppercase font-unbounded active:bg-black-10 {% if current_route == 'app_categories' %}{{ active_classes }}{% else %}{{ default_classes }}{% endif %}">
            <i data-lucide="layout-grid" class="mb-1 w-6 h-6 stroke-2-5"></i>
            <span>Категорії</span>
        </a>
        <a href="{{ path('app_authors') }}" data-skeleton="authors" class="flex-1 flex flex-col items-center justify-center py-4 text-primary text-xs transition-all uppercase font-unbounded active:bg-black-10 {% if current_route == 'app_authors' %}{{ active_classes }}{% else %}{{ default_classes }}{% endif %}">
            <i data-lucide="users" class="mb-1 w-6 h-6 stroke-2-5"></i>
            <span>Автори</span>
        </a>
        <a href="{{ path('app_notifications') }}" data-skeleton="notifications" class="flex-1 flex flex-col items-center justify-center py-4 text-primary text-xs transition-all uppercase font-unbounded active:bg-black-10 {% if current_route == 'app_notifications' %}{{ active_classes }}{% else %}{{ default_classes }}{% endif %}">
            <div class="relative">
                <i data-lucide="bell" class="mb-1 w-6 h-6 stroke-2-5"></i>
                <span id="unread-count-badge" class="hidden absolute top-[-6px] right-[-8px] bg-accent text-white font-unbounded text-[10px] font-bold py-0-5 px-1 rounded leading-none">0</span>
            </div>
            <span class="mt-1">Сповіщ.</span>
        </a>
        <a href="{{ path('app_profile') }}" data-skeleton="profile" class="flex-1 flex flex-col items-center justify-center py-4 text-primary text-xs transition-all uppercase font-unbounded active:bg-black-10 {% if current_route == 'app_profile' %}{{ active_classes }}{% else %}{{ default_classes }}{% endif %}">
            <i data-lucide="user" class="mb-1 w-6 h-6 stroke-2-5"></i>
            <span>Профіль</span>
        </a>
    </nav>
    {% endblock %}

    <script type="module" src="https://unpkg.com/@hotwired/turbo@8.0.4/dist/turbo.es2017-esm.js"></script>
    <script>
        window.APP_CONFIG = {
            mercureUrl: '{{ mercure("machinima/updates")|escape("js") }}'
        };

        let adjustPaddingFrame;
        function adjustBottomPadding() {
            if (adjustPaddingFrame) cancelAnimationFrame(adjustPaddingFrame);
            
            adjustPaddingFrame = requestAnimationFrame(() => {
                const bottomFixedElements = document.querySelectorAll('.fixed.bottom-0');
                let maxPadding = 0;
                
                bottomFixedElements.forEach(el => {
                    if (window.getComputedStyle(el).display !== 'none') {
                        const height = el.offsetHeight;
                        if (height > maxPadding) maxPadding = height;
                    }
                });
                
                // Set CSS variable instead of directly manipulating styles
                document.documentElement.style.setProperty('--bottom-overlay-height', maxPadding + 'px');
            });
        }
        
        // Trigger recalculation on key events
        document.addEventListener('DOMContentLoaded', adjustBottomPadding);
        window.addEventListener('resize', adjustBottomPadding);
        document.addEventListener('turbo:load', adjustBottomPadding);
        document.addEventListener('turbo:render', adjustBottomPadding);
        
        // Optimized MutationObserver for DOM changes
        const observer = new MutationObserver(adjustBottomPadding);
        observer.observe(document.body, { childList: true, subtree: true });
    </script>
    <script src="/js/app.js?v={{ random() }}"></script>
    {% include 'components/skeletons.html.twig' %}
    {% block javascripts %}{% endblock %}
</body>
</html>
