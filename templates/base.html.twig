<!doctype html>
<html lang="uk">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, shrink-to-fit=no" />
    <title>{% block title %}Morf TMA{% endblock %}</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link rel="stylesheet" href="/css/index.css?v={{ random() }}">
    <link rel="stylesheet" href="/css/App.css?v={{ random() }}">
    <!-- Using Lucide icons to match the React components -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
    <div class="app-container" style="padding-bottom: 100px;">
        {% block body %}{% endblock %}

        {% block tabbar %}
        {% set current_route = app.request.attributes.get('_route') %}
        <nav class="tma-tabbar">
            <a href="{{ path('app_index') }}" class="tab-item {% if current_route == 'app_index' %}active{% endif %}" style="text-decoration: none;">
                <i data-lucide="play-square"></i>
                <span>Стрічка</span>
            </a>
            <a href="{{ path('app_categories') }}" class="tab-item {% if current_route == 'app_categories' %}active{% endif %}" style="text-decoration: none;">
                <i data-lucide="layout-grid"></i>
                <span>Категорії</span>
            </a>
            <a href="{{ path('app_authors') }}" class="tab-item {% if current_route == 'app_authors' %}active{% endif %}" style="text-decoration: none;">
                <i data-lucide="users"></i>
                <span>Автори</span>
            </a>
            <a href="{{ path('app_notifications') }}" class="tab-item {% if current_route == 'app_notifications' %}active{% endif %}" style="position: relative; text-decoration: none;">
                <i data-lucide="bell"></i>
                <span>Сповіщ.</span>
            </a>
        </nav>
        {% endblock %}
    </div>

    <script>
        // Init Telegram Web App
        const tg = window.Telegram?.WebApp;
        if (tg) {
            tg.ready();
            tg.expand();
            
            if (tg.initData) {
                // We are inside Telegram Mini App
                
                // Hide manual HTML back buttons
                document.addEventListener('DOMContentLoaded', () => {
                    document.querySelectorAll('.header-action-bar').forEach(el => {
                        el.style.display = 'none';
                    });
                });

                // Configure Native Telegram Back Button
                const currentRoute = '{{ app.request.attributes.get("_route") }}';
                const rootRoutes = ['app_index', 'app_categories', 'app_authors', 'app_notifications'];
                
                if (!rootRoutes.includes(currentRoute)) {
                    tg.BackButton.show();
                    tg.BackButton.onClick(() => {
                        window.history.back();
                    });
                } else {
                    tg.BackButton.hide();
                }
            }
        }
        
        // Initialize Lucide icons
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
        
        // Propagate Telegram initData to all internal links to prevent session loss
        // since Telegram WebViews often block or drop session cookies on navigation.
        document.addEventListener('DOMContentLoaded', () => {
            const initData = window.Telegram?.WebApp?.initData;
            if (initData) {
                document.querySelectorAll('a').forEach(a => {
                    if (a.href && a.href.startsWith(window.location.origin)) {
                        try {
                            const url = new URL(a.href);
                            if (!url.searchParams.has('initData')) {
                                url.searchParams.set('initData', initData);
                                a.href = url.toString();
                            }
                        } catch (e) {
                            console.error('Failed to parse URL', e);
                        }
                    }
                });
            }
        });

        // Optional haptic feedback helper
        function haptic() {
            if (window.Telegram?.WebApp?.HapticFeedback) {
                window.Telegram.WebApp.HapticFeedback.impactOccurred('light');
            }
        }

        // Add haptic to tab clicks
        document.querySelectorAll('.tab-item').forEach(item => {
            item.addEventListener('click', haptic);
        });
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>
