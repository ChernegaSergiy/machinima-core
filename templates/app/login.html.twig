{% extends 'base.html.twig' %}

{% block title %}Вхід{% endblock %}

{% block body %}
<div class="container" style="min-height: 100vh; display: flex; align-items: center; justify-content: center; padding-bottom: 0;">
    <div class="profile-header" style="width: 100%;">
        <div class="profile-avatar" style="margin-bottom: 24px;">
            <i data-lucide="lock" style="width: 40px; height: 40px;"></i>
        </div>
        
        <h1 class="profile-name" style="margin-bottom: 12px;">Тільки через Telegram</h1>
        <p class="profile-bio" style="margin-bottom: 24px;">
            Цей застосунок розроблено спеціально для використання всередині Telegram.
        </p>
        
        <a href="https://t.me/MorfTutorialBot" class="action-button primary-btn" style="width: 100%; justify-content: center;">
            <i data-lucide="external-link" style="margin-right: 8px; width: 18px; height: 18px;"></i>
            Відкрити бота
        </a>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (window.Telegram && window.Telegram.WebApp && window.Telegram.WebApp.initData) {
            const initData = window.Telegram.WebApp.initData;
            
            // Show a loading state if desired, but we'll be fast
            document.querySelector('.profile-bio').innerText = 'Авторизація...';
            
            fetch('/login', {
                method: 'POST',
                credentials: 'same-origin',
                headers: {
                    'X-Telegram-Init-Data': initData
                }
            }).then(response => {
                if (response.ok) {
                    window.location.href = '/';
                } else {
                    document.querySelector('.profile-bio').innerText = 'Помилка авторизації. Перевірте підключення.';
                }
            }).catch(e => {
                document.querySelector('.profile-bio').innerText = 'Помилка мережі.';
            });
        }
    });
</script>
{% endblock %}
