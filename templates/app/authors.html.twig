{% extends 'base.html.twig' %}

{% block title %}Автори{% endblock %}

{% block body %}
<div class="tma-list">
    <h2 class="tma-section-header">Популярні автори</h2>
    {% for author in authors %}
        <a href="{{ path('app_author', {id: author.id}) }}" class="tma-list-item" style="text-decoration: none; color: inherit;">
            <div class="tma-avatar" style="width: 40px; height: 40px; margin-right: 16px;">
                <i data-lucide="user" style="color: var(--tg-theme-text-color);"></i>
            </div>
            <div class="tma-list-text">{{ author.name }}</div>
            <i data-lucide="chevron-right" style="color: var(--tg-theme-hint-color);"></i>
        </a>
    {% else %}
        <div style="padding: 16px; text-align: center; color: var(--tg-theme-hint-color);">
            Немає авторів
        </div>
    {% endfor %}
</div>
{% endblock %}
