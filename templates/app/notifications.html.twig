{% extends 'base.html.twig' %}

{% block title %}Сповіщення{% endblock %}

{% block body %}
<div class="pb-32 max-w-xl mx-auto p-4">
    <div class="flex justify-between items-center mb-6 pb-4 border-b-3">
        <h2 class="text-xl font-bold uppercase text-brutal flex items-center gap-2 m-0">
            <i data-lucide="bell" class="w-8 h-8"></i>
            СПОВІЩЕННЯ
        </h2>
        
        {% set unread_count = notifications|filter(n => not n.isRead)|length %}
        {% if unread_count > 0 %}
            <button onclick="markAllRead()" class="inline-flex items-center justify-center px-3 py-2 text-xs font-bold uppercase text-brutal bg-brutal border-3 shadow-brutal-sm active-brutal-sm cursor-pointer transition-all outline-none">
                <i data-lucide="check-circle" class="icon-sm mr-1"></i> ПРОЧИТАНО
            </button>
        {% endif %}
    </div>

    {% if notifications|length == 0 %}
        <div class="p-8 text-center text-brutal border-3 flex flex-col items-center">
            <i data-lucide="bell" class="icon-lg mb-4 opacity-50"></i>
            <span class="font-bold uppercase opacity-50">Немає сповіщень</span>
        </div>
    {% else %}
        <div class="flex flex-col gap-4">
            {% for notif in notifications %}
                <div onclick="handleClick({{ notif.id }}, {{ notif.isRead ? 'true' : 'false' }}, '{{ notif.type }}', '{{ notif.targetId }}')"
                    class="p-4 border-3 flex gap-3 cursor-pointer transition-all {% if notif.isRead %}bg-brutal active-brutal-sm{% else %}bg-brutal-secondary shadow-brutal active-bg-brutal{% endif %}"
                >
                    <div class="w-10 h-10 shrink-0 flex items-center justify-center bg-brutal-border text-brutal-bg border-2">
                        {% if notif.type == 'new_comment' %}
                            <i data-lucide="message-circle" class="icon-sm"></i>
                        {% else %}
                            <i data-lucide="bell" class="icon-sm"></i>
                        {% endif %}
                    </div>
                    <div class="flex-1">
                        <div class="mb-1 text-sm font-bold uppercase text-brutal">
                            {% if notif.type == 'new_comment' %}НОВИЙ КОМЕНТАР{% else %}СПОВІЩЕННЯ{% endif %}
                            {% if not notif.isRead %}
                                <span class="ml-2 text-xs text-brutal-bg bg-brutal-border px-1">НОВЕ</span>
                            {% endif %}
                        </div>
                        <div class="text-base font-semibold text-brutal break-words">
                            {{ notif.message }}
                        </div>
                        <div class="mt-2 text-xs font-bold text-brutal opacity-80">
                            {{ notif.createdAt|date('d.m.Y H:i') }}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
<script>
    const currentUserId = {{ app.user ? app.user.id : 1 }};

    function markAllRead() {
        if (window.Telegram?.WebApp?.HapticFeedback) {
            window.Telegram.WebApp.HapticFeedback.impactOccurred('light');
        }
        fetch(`/api/user/${currentUserId}/notifications/read-all`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' }
        }).then(() => {
            if (typeof window.Turbo !== 'undefined') {
                window.Turbo.visit(window.location.href);
            } else {
                window.location.reload();
            }
        }).catch(err => console.error(err));
    }

    function handleClick(id, isRead, type, targetId) {
        if (window.Telegram?.WebApp?.HapticFeedback) {
            window.Telegram.WebApp.HapticFeedback.impactOccurred('light');
        }
        
        const proceed = () => {
            if (type === 'new_comment' && targetId) {
                if (typeof window.Turbo !== 'undefined') {
                    window.Turbo.visit(`/post/${targetId}`);
                } else {
                    window.location.href = `/post/${targetId}`;
                }
            }
        };

        if (!isRead) {
            fetch(`/api/notifications/${id}/read`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ user_id: currentUserId })
            }).then(() => {
                proceed();
            }).catch(err => console.error(err));
        } else {
            proceed();
        }
    }
</script>
{% endblock %}
