{% extends 'base.html.twig' %}

{% block title %}Сповіщення{% endblock %}

{% block body %}
<div class="w-full max-w-600 mx-auto p-4">
    <div class="flex items-center justify-between mb-6 pb-3 border-b-2 border-border">
        <h1 class="text-3xl font-bold m-0 font-unbounded tracking-tight uppercase">Сповіщення</h1>
        {% set unread_count = notifications|filter(n => not n.isRead)|length %}
        {% if unread_count > 0 %}
            <button class="bg-border text-surface py-1 px-3 rounded font-bold text-sm uppercase inline-flex items-center justify-center cursor-pointer border-2 border-border shadow-btn transition-all font-unbounded active:translate-brutal-sm active:shadow-xs" onclick="markAllAsRead()"><i data-lucide="check-circle" class="w-4 h-4 mr-1-5 stroke-2-5"></i> Прочитано</button>
        {% endif %}
    </div>
    
    {% for notif in notifications %}
        {% if notif.targetId %}
            {% set target_url = path('app_notification_redirect', {'id': notif.id}) %}
            <a href="{{ target_url }}" data-skeleton="{{ notif.targetType }}" class="flex items-center p-4 rounded border-2 mb-4 cursor-pointer transition-all shadow-brutal active:translate-brutal active:shadow-none no-underline text-inherit border-border bg-surface notification-item">
                <div class="w-12 h-12 rounded bg-surface flex items-center justify-center text-primary mr-4 shrink-0 border-2 border-border shadow-brutal-sm"><i data-lucide="bell" class="w-6 h-6 stroke-2"></i></div>
                <div class="flex-1">
                    <div class="flex items-center text-lg font-bold mb-1 font-unbounded tracking-tight uppercase text-primary">Сповіщення {% if not notif.isRead %}<span class="bg-accent text-white py-0-5 px-2 rounded text-[10px] font-bold ml-2 uppercase font-unbounded inline-block">Нове</span>{% endif %}</div>
                    <div class="text-[14px] text-primary mb-1 leading-normal font-semibold">{{ notif.message }}</div>
                    <div class="text-[12px] text-muted font-bold uppercase"><time class="local-time" datetime="{{ notif.createdAt|date('c') }}" data-format="datetime">{{ notif.createdAt|date('d.m.Y H:i') }}</time></div>
                </div>
            </a>
        {% else %}
            <div class="flex items-center p-4 rounded border-2 mb-4 transition-all shadow-brutal text-inherit no-underline border-border bg-surface notification-item">
                <div class="w-12 h-12 rounded bg-surface flex items-center justify-center text-primary mr-4 shrink-0 border-2 border-border shadow-brutal-sm"><i data-lucide="bell" class="w-6 h-6 stroke-2"></i></div>
                <div class="flex-1">
                    <div class="flex items-center text-lg font-bold mb-1 font-unbounded tracking-tight uppercase text-primary">Сповіщення {% if not notif.isRead %}<span class="bg-accent text-white py-0-5 px-2 rounded text-[10px] font-bold ml-2 uppercase font-unbounded inline-block">Нове</span>{% endif %}</div>
                    <div class="text-[14px] text-primary mb-1 leading-normal font-semibold">{{ notif.message }}</div>
                    <div class="text-[12px] text-muted font-bold uppercase"><time class="local-time" datetime="{{ notif.createdAt|date('c') }}" data-format="datetime">{{ notif.createdAt|date('d.m.Y H:i') }}</time></div>
                </div>
            </div>
        {% endif %}
    {% else %}
        <div class="text-center py-16 px-4 text-primary border-2 border-dashed border-border rounded my-8 bg-black-2">
            <i data-lucide="bell-off" class="w-12 h-12 stroke-1-5 opacity-80 mb-4 mx-auto block"></i>
            <div class="font-unbounded font-bold tracking-tight uppercase">У вас немає нових сповіщень</div>
        </div>
    {% endfor %}
</div>

<script>
async function markAllAsRead() {
    try {
        const btn = document.querySelector('button[onclick="markAllAsRead()"]');
        if (btn) {
            btn.style.opacity = '0.5';
            btn.style.pointerEvents = 'none';
        }
        const initData = window.__PLATFORM__?.initData || window.Telegram?.WebApp?.initData;
        const headers = { 'Content-Type': 'application/json' };
        if (initData && typeof initData === 'string') {
            headers['X-Telegram-Init-Data'] = initData.replace(/[^\x20-\x7E]/g, '');
        }
        const res = await fetch('/api/notifications/read', { method: 'POST', headers: headers });
        if (res.ok) {
            if (typeof Turbo !== 'undefined') {
                Turbo.visit(window.location.href, { action: "replace" });
            } else {
                window.location.reload();
            }
        }
    } catch(e) {
        console.error(e);
    }
}
</script>
{% endblock %}
