{% extends 'base.html.twig' %}

{% block title %}Сповіщення{% endblock %}

{% block body %}
<div class="container">
    <div class="page-header-flex" style="margin-top: 16px;">
        <h1 class="page-title">Сповіщення</h1>
        {% set unread_count = notifications|filter(n => not n.isRead)|length %}
        {% if unread_count > 0 %}
            <button class="action-button small-btn"><i data-lucide="check-circle" style="width:16px;height:16px;margin-right:6px;"></i> Прочитано</button>
        {% endif %}
    </div>
    
    {% for notif in notifications %}
        <div class="list-item {% if not notif.isRead %}unread{% endif %}">
            <div class="list-icon"><i data-lucide="bell"></i></div>
            <div class="list-content">
                <div class="list-title">Сповіщення {% if not notif.isRead %}<span class="badge">Нове</span>{% endif %}</div>
                <div class="list-desc">{{ notif.message }}</div>
                <div class="list-meta">{{ notif.createdAt|date('d.m.Y H:i') }}</div>
            </div>
        </div>
    {% else %}
        <div class="empty-state">
            <i data-lucide="bell-off"></i>
            <div class="empty-state-text">У вас немає нових сповіщень</div>
        </div>
    {% endfor %}
</div>
{% endblock %}
