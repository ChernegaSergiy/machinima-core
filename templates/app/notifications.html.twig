{% extends 'base.html.twig' %}

{% block title %}Сповіщення{% endblock %}

{% block body %}
<div class="container">
    <div class="page-header-flex">
        <h1 class="page-title">Сповіщення</h1>
        {% set unread_count = notifications|filter(n => not n.isRead)|length %}
        {% if unread_count > 0 %}
            <button class="action-button small-btn" onclick="markAllAsRead()"><i data-lucide="check-circle" class="w-4 h-4 mr-1-5"></i> Прочитано</button>
        {% endif %}
    </div>
    
    {% for notif in notifications %}
        {% if notif.targetId %}
            {% set target_url = path('app_notification_redirect', {'id': notif.id}) %}
            <a href="{{ target_url }}" data-skeleton="{{ notif.targetType }}" class="list-item text-inherit no-underline {% if not notif.isRead %}unread{% endif %}">
                <div class="list-icon"><i data-lucide="bell"></i></div>
                <div class="list-content">
                    <div class="list-title">Сповіщення {% if not notif.isRead %}<span class="badge">Нове</span>{% endif %}</div>
                    <div class="list-desc">{{ notif.message }}</div>
                    <div class="list-meta"><time class="local-time" datetime="{{ notif.createdAt|date('c') }}" data-format="datetime">{{ notif.createdAt|date('d.m.Y H:i') }}</time></div>
                </div>
            </a>
        {% else %}
            <div class="list-item text-inherit no-underline {% if not notif.isRead %}unread{% endif %}">
                <div class="list-icon"><i data-lucide="bell"></i></div>
                <div class="list-content">
                    <div class="list-title">Сповіщення {% if not notif.isRead %}<span class="badge">Нове</span>{% endif %}</div>
                    <div class="list-desc">{{ notif.message }}</div>
                    <div class="list-meta"><time class="local-time" datetime="{{ notif.createdAt|date('c') }}" data-format="datetime">{{ notif.createdAt|date('d.m.Y H:i') }}</time></div>
                </div>
            </div>
        {% endif %}
    {% else %}
        <div class="empty-state">
            <i data-lucide="bell-off"></i>
            <div class="empty-state-text">У вас немає нових сповіщень</div>
        </div>
    {% endfor %}
</div>

<script>
async function markAllAsRead() {
    try {
        const btn = document.querySelector('button[onclick="markAllAsRead()"]');
        if (btn) {
            btn.style.opacity = '0.5';
            btn.style.pointerEvents = 'none';
        }
        const tgData = window.Telegram?.WebApp?.initData;
        const headers = { 'Content-Type': 'application/json' };
        if (tgData && typeof tgData === 'string') {
            headers['X-Telegram-Init-Data'] = tgData.replace(/[^\x20-\x7E]/g, '');
        }
        const res = await fetch('/api/notifications/read', { method: 'POST', headers: headers });
        if (res.ok) {
            if (typeof Turbo !== 'undefined') {
                Turbo.visit(window.location.href, { action: "replace" });
            } else {
                window.location.reload();
            }
        }
    } catch(e) {
        console.error(e);
    }
}
</script>
{% endblock %}
