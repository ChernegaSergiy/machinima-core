{% extends 'base.html.twig' %}

{% block title %}Стрічка{% endblock %}

{% block body %}
<div class="container">
    <div class="page-header-flex">
        <h1 class="page-title">Стрічка</h1>
    </div>
    {% for project in feed %}
    <div class="card">
        <div class="card-header">
            <div class="avatar">
                <i data-lucide="user"></i>
            </div>
            <div class="author-info">
                <div class="author-name">{% if project.staff|length > 0 %}{{ project.staff|first.author.name }}{% else %}Автор невідомий{% endif %}</div>
                <div class="author-meta">{{ project.type }} • <time class="local-time" datetime="{{ project.createdAt|date('c') }}" data-format="date">{{ project.createdAt|date('d.m.Y') }}</time></div>
            </div>
        </div>
        
        <a href="{{ path('app_post', {id: project.id}) }}" data-skeleton="post">
            <h3 class="post-title">{{ project.title }}</h3>
        </a>
        
        <div class="post-desc">
            {{ project.description }}
        </div>
        
        <a href="{{ path('app_post', {id: project.id}) }}" data-skeleton="post" class="post-media">
            {% if project.coverFileId %}
                {% if project.coverFileId starts with 'http' %}
                    <img src="{{ project.coverFileId }}" alt="Cover" style="width: 100%; height: 100%; object-fit: cover; display: block;" loading="lazy" />
                {% else %}
                    <img src="{{ path('app_media', {fileId: project.coverFileId}) }}" alt="Cover" style="width: 100%; height: 100%; object-fit: cover; display: block;" loading="lazy" />
                {% endif %}
            {% else %}
                <i data-lucide="image" style="width:32px; height:32px;"></i>
            {% endif %}
        </a>
        
        <div class="post-actions" data-post-id="{{ project.id }}">
            <div class="action-item btn-like" onclick="interactFeed({{ project.id }}, 'like', this)" style="cursor:pointer;">
                <i data-lucide="heart"></i> <span class="likes-count">{{ project.likesCount }}</span>
            </div>
            <div class="action-item btn-dislike" onclick="interactFeed({{ project.id }}, 'dislike', this)" style="cursor:pointer;">
                <i data-lucide="thumbs-down"></i>
            </div>
            <div class="action-item ml-auto">
                <i data-lucide="eye"></i> <span class="views-count">{{ project.viewsCount }}</span>
            </div>
        </div>
    </div>
    {% else %}
    <div class="empty-state">
        <i data-lucide="inbox"></i>
        <div class="empty-state-text">Стрічка порожня</div>
    </div>
    {% endfor %}
</div>
{% endblock %}
