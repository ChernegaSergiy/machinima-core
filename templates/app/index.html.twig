{% extends 'base.html.twig' %}

{% block title %}Стрічка{% endblock %}

{% block body %}
<div class="container">
    {% for project in feed %}
    <div class="card">
        <div class="card-header">
            <div class="avatar">
                <i data-lucide="user"></i>
            </div>
            <div class="author-info">
                <div class="author-name">{% if project.staff|length > 0 %}{{ project.staff|first.author.name }}{% else %}Автор невідомий{% endif %}</div>
                <div class="author-meta">{{ project.type }} • {{ project.createdAt|date('d.m.Y') }}</div>
            </div>
        </div>
        
        <a href="{{ path('app_post', {id: project.id}) }}">
            <h3 class="post-title">{{ project.title }}</h3>
        </a>
        
        <div class="post-desc">
            {{ project.description }}
        </div>
        
        <a href="{{ path('app_post', {id: project.id}) }}" class="post-media">
            {% if project.coverFileId %}
                <span style="font-weight:700;">[Кобложка]</span>
            {% else %}
                <i data-lucide="image" style="width:32px; height:32px;"></i>
            {% endif %}
        </a>
        
        <div class="post-actions">
            <div class="action-item">
                <i data-lucide="heart"></i> {{ project.likesCount }}
            </div>
            <div class="action-item">
                <i data-lucide="thumbs-down"></i> {{ project.dislikesCount }}
            </div>
            <div class="action-item ml-auto">
                <i data-lucide="eye"></i> {{ project.viewsCount }}
            </div>
        </div>
    </div>
    {% else %}
    <div class="empty-state">
        <i data-lucide="inbox"></i>
        <div class="empty-state-text">Стрічка порожня</div>
    </div>
    {% endfor %}
</div>
{% endblock %}
