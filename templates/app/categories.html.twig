{% extends 'base.html.twig' %}

{% block title %}Категорії{% endblock %}

{% block body %}
<div class="container">
    <div class="page-header-flex" style="margin-top: 16px;">
        <h1 class="page-title">Категорії</h1>
    </div>
    
    {% for category in categories %}
        <a href="{{ path('app_category', {id: category.id}) }}" class="list-item">
            <div class="list-icon"><i data-lucide="layout-grid"></i></div>
            <div class="list-content">
                <div class="list-title">{{ category.name }}</div>
            </div>
            <i data-lucide="chevron-right" style="color: var(--text-muted); width: 20px;"></i>
        </a>
    {% else %}
        <div class="empty-state">
            <i data-lucide="inbox"></i>
            <div class="empty-state-text">Категорій не знайдено</div>
        </div>
    {% endfor %}
</div>
{% endblock %}
