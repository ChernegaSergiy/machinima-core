{% extends 'base.html.twig' %}

{% block title %}Категорії{% endblock %}

{% block body %}
<div class="w-full max-w-600 mx-auto p-4">
    <div class="flex items-center justify-between mb-6 pb-3 border-b-2 border-border">
        <h1 class="text-3xl font-bold m-0 font-unbounded tracking-tight uppercase">Категорії</h1>
    </div>
    
    {% for category in categories %}
        <a href="{{ path('app_category', {id: category.id}) }}" data-skeleton="category" class="flex items-center p-4 bg-surface rounded border-2 border-border mb-4 cursor-pointer transition-all shadow-brutal active:translate-brutal active:shadow-none no-underline">
            <div class="w-12 h-12 rounded bg-surface flex items-center justify-center text-primary mr-4 shrink-0 border-2 border-border shadow-brutal-sm"><i data-lucide="layout-grid" class="w-6 h-6 stroke-2"></i></div>
            <div class="flex-1">
                <div class="flex items-center text-lg font-bold m-0 font-unbounded tracking-tight uppercase text-primary">{{ category.name }}</div>
            </div>
            <i data-lucide="chevron-right" class="text-muted w-6 h-6 stroke-2"></i>
        </a>
    {% else %}
        <div class="text-center py-16 px-4 text-primary border-2 border-dashed border-border rounded my-8 bg-black-2">
            <i data-lucide="inbox" class="w-12 h-12 stroke-1.5 opacity-80 mb-4 mx-auto block"></i>
            <div class="font-unbounded font-bold tracking-tight uppercase">Категорій не знайдено</div>
        </div>
    {% endfor %}
</div>
{% endblock %}
