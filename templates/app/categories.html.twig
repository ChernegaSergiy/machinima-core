{% extends 'base.html.twig' %}

{% block title %}Категорії{% endblock %}

{% block body %}
<div class="pb-32 max-w-xl mx-auto p-4">
    <h2 class="text-xl font-bold uppercase text-brutal-bg bg-brutal-border p-3 mb-6 tracking-wide border-3 shadow-brutal-sm">Жанри</h2>
    
    <div class="flex flex-col gap-4">
        {% for category in categories %}
            <a href="{{ path('app_category', {id: category.id}) }}" class="flex items-center p-3 bg-brutal border-3 shadow-brutal active-brutal cursor-pointer transition-all">
                <div class="w-12 h-12 shrink-0 flex items-center justify-center bg-brutal-border text-brutal-bg border-2 mr-4 font-bold">
                    <i data-lucide="layout-grid" class="icon-md"></i>
                </div>
                <div class="flex-1 text-lg font-bold uppercase tracking-tight text-brutal">{{ category.name }}</div>
                <i data-lucide="chevron-right" class="icon-md text-brutal"></i>
            </a>
        {% else %}
            <div class="p-8 text-center text-brutal border-3 border-dashed flex flex-col items-center">
                <i data-lucide="layout-grid" class="icon-lg mb-4 opacity-50"></i>
                <span class="font-bold uppercase opacity-50">Немає категорій</span>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
