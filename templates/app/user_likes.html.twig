{% extends 'base.html.twig' %}

{% block title %}Вподобання користувача{% endblock %}

{% block body %}
<div class="sticky top-0 left-0 right-0 bg-surface border-b-2 border-border flex items-center p-4 z-90 hide-on-tma">
    <a href="{{ path('app_profile') }}" class="font-bold flex items-center uppercase font-unbounded tracking-tight no-underline text-inherit cursor-pointer active:opacity-80"><i data-lucide="arrow-left" class="mr-2 w-6 h-6 stroke-2-5"></i> Назад</a>
</div>

<div class="w-full max-w-600 mx-auto p-4">
    <div class="flex items-center justify-between mb-6 pb-3 border-b-2 border-border">
        <h1 class="text-3xl font-bold m-0 font-unbounded tracking-tight uppercase line-clamp-1">Вподобання</h1>
    </div>
    
    {% for project in feed %}
    <div class="bg-surface border-2 border-border rounded p-4 mb-6 shadow-brutal">
        {% if project.staff|length > 0 %}
            <a href="{{ path('app_author', {id: project.staff|first.author.id}) }}" data-skeleton="author" class="flex items-center mb-4 no-underline text-inherit group transition-all">
                <div class="w-11 h-11 rounded bg-surface border-2 border-border shadow-brutal-sm flex items-center justify-center mr-3 text-primary shrink-0 group-active:translate-brutal-sm group-active:shadow-xs transition-all"><i data-lucide="user" class="w-6 h-6 stroke-2"></i></div>
                <div>
                    <div class="font-bold text-lg text-primary mb-0-5 font-unbounded tracking-tight uppercase group-active:text-accent transition-colors">{{ project.staff|first.author.name }}</div>
                    <div class="text-sm text-muted font-semibold uppercase">{{ project.type }} • <time class="local-time" datetime="{{ project.createdAt|date('c') }}" data-format="date">{{ project.createdAt|date('d.m.Y') }}</time></div>
                </div>
            </a>
        {% else %}
            <div class="flex items-center mb-4">
                <div class="w-11 h-11 rounded bg-surface border-2 border-border shadow-brutal-sm flex items-center justify-center mr-3 text-primary shrink-0"><i data-lucide="user" class="w-6 h-6 stroke-2"></i></div>
                <div>
                    <div class="font-bold text-lg text-primary mb-0-5 font-unbounded tracking-tight uppercase">Автор невідомий</div>
                    <div class="text-sm text-muted font-semibold uppercase">{{ project.type }} • <time class="local-time" datetime="{{ project.createdAt|date('c') }}" data-format="date">{{ project.createdAt|date('d.m.Y') }}</time></div>
                </div>
            </div>
        {% endif %}
        
        <a href="{{ path('app_post', {id: project.id}) }}" data-skeleton="post" class="block no-underline">
            <h3 class="text-xl font-bold m-0 mb-3 leading-snug text-primary font-unbounded tracking-tight uppercase">{{ project.title }}</h3>
        </a>
        
        <div class="text-base text-primary leading-relaxed mb-4 font-semibold line-clamp-3">
            {{ project.description }}
        </div>
        
        <a href="{{ path('app_post', {id: project.id}) }}" data-skeleton="post" class="w-full aspect-video bg-surface border-2 border-border rounded flex items-center justify-center text-primary overflow-hidden relative">
            {% if project.coverFileId %}
                {% if project.coverFileId starts with 'http' %}
                    <img src="{{ project.coverFileId }}" alt="Cover" class="w-full h-full object-cover block" loading="lazy" />
                {% else %}
                    <img src="{{ path('app_media', {fileId: project.coverFileId}) }}" alt="Cover" class="w-full h-full object-cover block" loading="lazy" />
                {% endif %}
            {% else %}
                <i data-lucide="image" class="w-8 h-8 stroke-1-5"></i>
            {% endif %}
        </a>
        
        <div class="post-actions flex items-center gap-3 mt-4 pt-4 border-t-2 border-border" data-post-id="{{ project.id }}">
            <div class="btn-like inline-flex items-center justify-center gap-1-5 text-sm font-bold text-primary cursor-pointer transition-all py-1-5 px-3 bg-surface border-2 border-border rounded shadow-brutal-sm h-10 active:translate-brutal-sm active:shadow-xs" onclick="interactFeed({{ project.id }}, 'like', this)">
                <i data-lucide="heart" class="w-5 h-5 stroke-2-5"></i> <span class="likes-count">{{ project.likesCount }}</span>
            </div>
            <div class="btn-dislike inline-flex items-center justify-center gap-1-5 text-sm font-bold text-primary cursor-pointer transition-all py-1-5 px-3 bg-surface border-2 border-border rounded shadow-brutal-sm h-10 active:translate-brutal-sm active:shadow-xs" onclick="interactFeed({{ project.id }}, 'dislike', this)">
                <i data-lucide="thumbs-down" class="w-5 h-5 stroke-2-5"></i>
            </div>
            <div class="inline-flex items-center justify-center gap-1-5 text-sm font-bold text-primary py-1-5 px-3 bg-surface border-2 border-border rounded shadow-brutal-sm h-10 ml-auto pointer-events-none">
                <i data-lucide="eye" class="w-5 h-5 stroke-2-5"></i> <span class="views-count">{{ project.viewsCount }}</span>
            </div>
        </div>
    </div>
    {% else %}
        <div class="text-center py-16 px-4 text-primary border-2 border-dashed border-border rounded my-8 bg-black-2">
            <i data-lucide="heart" class="w-12 h-12 stroke-1-5 opacity-80 mb-4 mx-auto block"></i>
            <div class="font-unbounded font-bold tracking-tight uppercase">Немає вподобань</div>
        </div>
    {% endfor %}
</div>
{% endblock %}
