{% extends 'base.html.twig' %}

{% block title %}{{ author.name }}{% endblock %}

{% block body %}
<div class="top-nav">
    <a href="{{ path('app_authors') }}" class="back-btn"><i data-lucide="arrow-left"></i> Назад</a>
</div>

<div class="container">
    <div class="profile-header">
        <div class="profile-avatar">
            <i data-lucide="user" style="width:40px; height:40px;"></i>
        </div>
        <h1 class="profile-name">{{ author.name }}</h1>
        
        {% if author.biography %}
            <p class="profile-bio">{{ author.biography }}</p>
        {% endif %}
        
        <div style="display: flex; gap: 8px; justify-content: center; align-items: center; margin-bottom: 24px;">
            {% if author.channelLink %}
                <a href="{{ author.channelLink }}" target="_blank" class="action-button primary-btn" style="margin: 0; min-width: 120px;">
                    Канал
                </a>
            {% endif %}
            
            {% if app.user %}
                <button id="follow-btn" class="action-button {{ isFollowing ? 'secondary-btn' : 'primary-btn' }}" style="margin: 0; min-width: 120px;" onclick="toggleFollow()">
                    {{ isFollowing ? 'Відписатися' : 'Підписатися' }}
                </button>
                <script>
                    let isFollowing = {{ isFollowing ? 'true' : 'false' }};
                    function toggleFollow() {
                        const btn = document.getElementById('follow-btn');
                        btn.disabled = true;
                        
                        const endpoint = isFollowing ? '{{ path('app_author_unfollow', {id: author.id}) }}' : '{{ path('app_author_follow', {id: author.id}) }}';
                        
                        fetch(endpoint, { method: 'POST' })
                            .then(res => res.json())
                            .then(data => {
                                isFollowing = !isFollowing;
                                btn.textContent = isFollowing ? 'Відписатися' : 'Підписатися';
                                btn.className = 'action-button ' + (isFollowing ? 'secondary-btn' : 'primary-btn');
                            })
                            .finally(() => {
                                btn.disabled = false;
                            });
                    }
                </script>
            {% endif %}
        </div>
    </div>
    
    <h2 class="section-title">Проєкти автора ({{ projects|length }})</h2>
    
    {% for project in projects %}
    <div class="card">
        <div class="card-header">
            <div class="avatar"><i data-lucide="user"></i></div>
            <div class="author-info">
                <div class="author-name">{{ author.name }}</div>
                <div class="author-meta">{{ project.type }} • <time class="local-time" datetime="{{ project.createdAt|date('c') }}" data-format="date">{{ project.createdAt|date('d.m.Y') }}</time></div>
            </div>
        </div>
        
        <a href="{{ path('app_post', {id: project.id}) }}">
            <h3 class="post-title">{{ project.title }}</h3>
        </a>
        
        <div class="post-desc">
            {{ project.description }}
        </div>
        
        <a href="{{ path('app_post', {id: project.id}) }}" class="post-media">
            {% if project.coverFileId %}
                {% if project.coverFileId starts with 'http' %}
                    <img src="{{ project.coverFileId }}" alt="Cover" style="width: 100%; height: 100%; object-fit: cover; display: block;" loading="lazy" />
                {% else %}
                    <img src="{{ path('app_media', {fileId: project.coverFileId}) }}" alt="Cover" style="width: 100%; height: 100%; object-fit: cover; display: block;" loading="lazy" />
                {% endif %}
            {% else %}
                <i data-lucide="image" style="width:32px; height:32px;"></i>
            {% endif %}
        </a>
        
        <div class="post-actions">
            <div class="action-item"><i data-lucide="heart"></i> {{ project.likesCount }}</div>
            <div class="action-item"><i data-lucide="thumbs-down"></i> {{ project.dislikesCount }}</div>
            <div class="action-item ml-auto"><i data-lucide="eye"></i> {{ project.viewsCount }}</div>
        </div>
    </div>
    {% else %}
    <div class="empty-state">
        <i data-lucide="inbox"></i>
        <div class="empty-state-text">Цей автор ще не має проєктів</div>
    </div>
    {% endfor %}
</div>
{% endblock %}
