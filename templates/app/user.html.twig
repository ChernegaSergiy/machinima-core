{% extends 'base.html.twig' %}

{% block title %}Профіль користувача{% endblock %}

{% block body %}
<div class="w-full max-w-600 mx-auto p-4">
    <div class="flex items-center justify-between mb-6 pb-3 border-b-2 border-border">
        <h1 class="text-3xl font-bold m-0 font-unbounded tracking-tight uppercase">Профіль</h1>
    </div>

    <!-- Personal Info Card -->
    <div class="text-center py-8 px-4 mb-8 bg-surface rounded border-2 border-border shadow-brutal">
        <div class="w-22 h-22 mx-auto mb-5 rounded bg-surface flex items-center justify-center text-primary border-2 border-border shadow-brutal overflow-hidden shrink-0">
            <img src="{{ path('app_avatar', {userId: targetUser.id}) }}" alt="Avatar" class="w-full h-full object-cover">
        </div>
        <h2 class="text-[26px] font-bold mb-3 m-0 font-unbounded tracking-tight uppercase">{{ name }}</h2>
        
        <span class="bg-border text-surface py-0-5 px-2 rounded text-xs font-bold uppercase font-unbounded inline-block">
            Користувач
        </span>
    </div>

    <!-- Stats -->
    <h2 class="text-xl font-bold mb-5 text-primary border-b-2 border-border pb-2 font-unbounded tracking-tight uppercase">Статистика</h2>
    <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="bg-surface border-2 border-border rounded p-4 text-center flex flex-col justify-center mb-0 transition-all shadow-brutal">
            <div class="flex justify-center items-center text-2xl font-bold mb-1 font-unbounded tracking-tight uppercase">{{ followingCount }}</div>
            <div class="text-[12px] text-muted font-bold uppercase">Підписок</div>
        </div>
        <div class="bg-surface border-2 border-border rounded p-4 text-center flex flex-col justify-center mb-0 transition-all shadow-brutal">
            <div class="flex justify-center items-center text-2xl font-bold mb-1 font-unbounded tracking-tight uppercase">{{ likesCount }}</div>
            <div class="text-[12px] text-muted font-bold uppercase">Вподобань</div>
        </div>
    </div>

    <div class="flex items-center p-4 bg-surface rounded border-2 border-border mb-4 transition-all shadow-brutal">
        <div class="w-12 h-12 rounded bg-surface flex items-center justify-center text-primary mr-4 shrink-0 border-2 border-border shadow-brutal-sm">
            <i data-lucide="shield-check" class="w-6 h-6 stroke-2"></i>
        </div>
        <div class="flex-1">
            <div class="flex items-center text-lg font-bold mb-1 font-unbounded tracking-tight uppercase">Акаунт створено</div>
            <div class="text-[14px] text-primary mb-1 leading-normal font-semibold">{{ targetUser.createdAt ? targetUser.createdAt|date('d.m.Y') : 'Невідомо' }}</div>
        </div>
    </div>

    {% if author %}
        <a href="{{ path('app_author', {id: author.id}) }}" class="flex items-center p-4 bg-surface rounded border-2 border-border mb-4 cursor-pointer transition-all shadow-brutal active:translate-brutal active:shadow-none no-underline text-inherit">
            <div class="w-12 h-12 rounded bg-surface flex items-center justify-center text-primary mr-4 shrink-0 border-2 border-border shadow-brutal-sm">
                <i data-lucide="user-check" class="w-6 h-6 stroke-2"></i>
            </div>
            <div class="flex-1">
                <div class="flex items-center text-lg font-bold mb-1 font-unbounded tracking-tight uppercase">Сторінка автора</div>
                <div class="text-[14px] text-primary mb-1 leading-normal font-semibold">Переглянути роботи та проєкти</div>
            </div>
            <i data-lucide="chevron-right" class="text-muted w-6 h-6 stroke-2"></i>
        </a>
    {% endif %}
</div>
{% endblock %}
