{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
<div class="sticky top-0 left-0 right-0 bg-surface border-b-2 border-border flex items-center p-4 z-90 hide-on-tma">
    <a href="{{ path('app_index') }}" class="font-bold flex items-center uppercase font-unbounded tracking-tight no-underline text-inherit cursor-pointer active:opacity-80"><i data-lucide="arrow-left" class="mr-2 w-6 h-6 stroke-2-5"></i> Назад</a>
</div>

<div class="w-full max-w-600 mx-auto p-4 pb-20">
    <div class="bg-surface border-2 border-border rounded p-4 mb-6 shadow-brutal">
        <div class="flex items-center mb-4">
            <div class="w-11 h-11 rounded bg-surface border-2 border-border shadow-brutal-sm flex items-center justify-center mr-3 text-primary shrink-0"><i data-lucide="user" class="w-6 h-6 stroke-2"></i></div>
            <div>
                <div class="font-bold text-lg text-primary mb-0-5 font-unbounded tracking-tight uppercase">{% if post.staff|length > 0 %}{{ post.staff|first.author.name }}{% else %}Автор невідомий{% endif %}</div>
                <div class="text-sm text-muted font-semibold uppercase">{{ post.type }} • <time class="local-time" datetime="{{ post.createdAt|date('c') }}" data-format="datetime">{{ post.createdAt|date('d.m.Y H:i') }}</time></div>
            </div>
        </div>
        
        <h1 class="text-[26px] font-bold mb-5 leading-snug text-primary font-unbounded tracking-tight uppercase">{{ post.title }}</h1>
        
        <div class="text-lg text-primary mb-6 leading-relaxed font-semibold">
            {{ post.description|nl2br }}
        </div>
        
        <div class="w-full aspect-video bg-surface border-2 border-border rounded flex items-center justify-center text-primary overflow-hidden relative mb-6">
            {% if post.coverFileId %}
                {% if post.coverFileId starts with 'http' %}
                    <img src="{{ post.coverFileId }}" alt="Cover" class="w-full h-full object-cover block" />
                {% else %}
                    <img src="{{ path('app_media', {fileId: post.coverFileId}) }}" alt="Cover" class="w-full h-full object-cover block" />
                {% endif %}
            {% else %}
                <i data-lucide="image" class="w-12 h-12 stroke-1-5"></i>
            {% endif %}
        </div>
        
        <div class="flex items-center gap-3 mt-4 pt-4 border-t-2 border-border" data-post-id="{{ post.id }}">
            <div class="inline-flex items-center justify-center gap-1-5 text-[14px] font-bold text-primary py-1-5 px-3 bg-surface border-2 border-border rounded shadow-brutal-sm h-10 select-none transition-all active:translate-brutal-sm active:shadow-xs cursor-pointer btn-like" onclick="interact('like', this)"><i data-lucide="heart" class="w-[18px] h-[18px] stroke-2-5"></i> <span id="likes-count">{{ post.likesCount }}</span></div>
            <div class="inline-flex items-center justify-center gap-1-5 text-[14px] font-bold text-primary py-1-5 px-3 bg-surface border-2 border-border rounded shadow-brutal-sm h-10 select-none transition-all active:translate-brutal-sm active:shadow-xs cursor-pointer btn-dislike" onclick="interact('dislike', this)"><i data-lucide="thumbs-down" class="w-[18px] h-[18px] stroke-2-5"></i></div>
            <div class="inline-flex items-center justify-center gap-1-5 text-[14px] font-bold text-primary py-1-5 px-3 bg-surface border-2 border-border rounded shadow-brutal-sm h-10 ml-auto"><i data-lucide="eye" class="w-[18px] h-[18px] stroke-2-5"></i> <span id="views-count">{{ post.viewsCount }}</span></div>
        </div>
    </div>

    {% if post.staff|length > 0 %}
    <h2 class="text-xl font-bold mb-5 text-primary border-b-2 border-border pb-2 font-unbounded tracking-tight uppercase">Команда проєкту</h2>
    <div class="mb-6">
        {% for staffItem in post.staff %}
            <div class="flex items-center p-4 bg-surface rounded border-2 border-border mb-4 shadow-brutal pointer-events-none">
                <div class="w-12 h-12 rounded bg-surface flex items-center justify-center text-primary mr-4 shrink-0 border-2 border-border shadow-brutal-sm">
                    <i data-lucide="user" class="w-6 h-6 stroke-2"></i>
                </div>
                <div class="flex-1">
                    <h3 class="flex items-center text-lg font-bold mb-1 font-unbounded tracking-tight uppercase text-primary m-0">{{ staffItem.author.name }}</h3>
                    <div class="text-[14px] text-primary mb-1 leading-normal font-semibold">{{ staffItem.role }}</div>
                </div>
            </div>
        {% endfor %}
    </div>
    {% endif %}

    <script>
        (function() {
            var userId = window.Telegram?.WebApp?.initDataUnsafe?.user?.id;
            var tgData = window.Telegram?.WebApp?.initData;
            
            // Apply owner-specific CSS immediately
            var style = document.createElement('style');
            var css = '.owner-actions[data-owner-id="' + userId + '"] { display: flex !important; }';
            
            // Verify moderator status asynchronously to bypass cache
            if (tgData) {
                fetch('/api/me', {
                    headers: { 'X-Telegram-Init-Data': tgData }
                })
                .then(r => r.json())
                .then(data => {
                    if (data.is_moderator) {
                        css += '\n.owner-actions { display: flex !important; }';
                        css += '\n.owner-actions:not([data-owner-id="' + userId + '"]) .edit-btn { display: none !important; }';
                        style.innerHTML = css;
                    }
                })
                .catch(e => console.error('Failed to verify moderator status:', e));
            }

            style.innerHTML = css;
            document.head.appendChild(style);
        })();
    </script>
    <h2 class="text-xl font-bold mb-5 text-primary border-b-2 border-border pb-2 font-unbounded tracking-tight uppercase">Коментарі (<span id="comment-count-number">{{ commentsCount }}</span>)</h2>
    
    <div id="comments-list">
        {% if commentsCount == 0 %}
            <div class="text-center py-16 px-4 text-primary border-2 border-dashed border-border rounded my-8 bg-black-2 empty-state">
                <i data-lucide="message-square" class="w-12 h-12 stroke-1-5 opacity-80 mb-4 mx-auto block"></i>
                <div class="font-unbounded font-bold tracking-tight uppercase">Немає коментарів</div>
            </div>
        {% else %}
            {% macro render_comment_tree(tree) %}
                {% for item in tree %}
                    <div class="bg-surface border-2 border-border rounded p-4 mb-4 shadow-brutal comment-item" id="comment-item-{{ item.entity.id }}">
                        <div class="flex items-center mb-3">
                            <div class="w-10 h-10 rounded bg-surface border-2 border-border shadow-brutal-sm overflow-hidden flex items-center justify-center mr-3 shrink-0"><img src="{{ path('app_avatar', {userId: item.entity.user.id}) }}" alt="" loading="lazy" class="w-full h-full object-cover block" /></div>
                            <div>
                                <div class="font-bold text-[15px] text-primary mb-0-5 font-unbounded tracking-tight uppercase">{{ item.entity.authorName }}</div>
                                <div class="text-[12px] text-muted font-bold uppercase"><time class="local-time" datetime="{{ item.entity.createdAt|date('c') }}" data-format="datetime">{{ item.entity.createdAt|date('d.m.Y H:i') }}</time></div>
                            </div>
                        </div>
                        <div class="text-[15px] text-primary leading-relaxed font-semibold break-words" id="comment-text-{{ item.entity.id }}">{{ item.entity.text }}</div>
                        <div class="flex gap-4 mt-3 items-center flex-wrap">
                            <button class="bg-transparent border-none p-0 text-[13px] font-bold text-muted cursor-pointer flex items-center gap-1 hover:text-primary transition-all font-unbounded uppercase" onclick="setReply({{ item.entity.id }}, '{{ item.entity.authorName|escape('js') }}')"><i data-lucide="corner-down-right" class="w-4 h-4 stroke-2-5"></i> Відповісти</button>
                            <div class="owner-actions hidden gap-4 flex-wrap" data-owner-id="{{ item.entity.user.id }}" data-cid="{{ item.entity.id }}">
                                <button class="bg-transparent border-none p-0 text-[13px] font-bold text-primary cursor-pointer flex items-center gap-1 transition-all font-unbounded uppercase edit-btn" onclick="startEditComment({{ item.entity.id }})"><i data-lucide="edit-2" class="w-4 h-4 stroke-2-5"></i></button>
                                <button class="bg-transparent border-none p-0 text-[13px] font-bold text-danger cursor-pointer flex items-center gap-1 transition-all font-unbounded uppercase delete-btn" onclick="deleteComment({{ item.entity.id }})"><i data-lucide="trash-2" class="w-4 h-4 stroke-2-5"></i></button>
                            </div>
                        </div>
                        
                        <div class="comment-reply-wrapper {% if item.children|length == 0 %}hidden{% endif %} ml-3 border-l-2 border-border pl-3 mt-4" id="replies-{{ item.entity.id }}">
                            {% if item.children|length > 0 %}
                                {{ _self.render_comment_tree(item.children) }}
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            {% endmacro %}
            
            {{ _self.render_comment_tree(commentTree) }}
        {% endif %}
    </div>
</div>

<div class="fixed bottom-0 left-0 right-0 bg-surface border-t-2 border-border p-3 z-90 pb-[max(12px,env(safe-area-inset-bottom))]">
    <form id="comment-form" onsubmit="submitComment(event)" class="flex items-center gap-3 w-full max-w-600 mx-auto">
        <input id="comment-input" type="text" placeholder="Написати коментар..." class="flex-1 py-3 px-4 bg-surface border-2 border-border rounded font-bold text-primary text-base outline-none shadow-brutal-sm transition-all focus:border-primary placeholder:text-muted placeholder:font-semibold" required />
        <button type="submit" class="w-12 h-12 bg-border text-surface border-2 border-border rounded flex items-center justify-center cursor-pointer shadow-brutal-sm transition-all active:translate-brutal-sm active:shadow-xs"><i data-lucide="send" class="w-5 h-5 stroke-2-5 relative -ml-1"></i></button>
    </form>
</div>

<script>
    window.currentUserId = window.Telegram?.WebApp?.initDataUnsafe?.user?.id;
    window.authorName = window.Telegram?.WebApp?.initDataUnsafe?.user?.first_name || 'Користувач';
    window.postId = {{ post.id }};
    window.replyToId = null;
    window.editModeId = null;

    function toggleSvgFill(el, active) {
        const svg = el && el.querySelector('svg');
        if (svg) svg.setAttribute('fill', active ? 'currentColor' : 'none');
    }

    window.interact = async function(type, btnElement) {
        let step = 'init';
        try {
            step = 'tgData';
            const tgData = window.Telegram?.WebApp?.initData;
            
            step = 'headers';
            const headers = { 'Content-Type': 'application/json' };
            if (tgData && typeof tgData === 'string') {
                const cleaned = tgData.replace(/[^\x20-\x7E]/g, '').trim();
                if (cleaned.length > 0) {
                    headers['X-Telegram-Init-Data'] = cleaned;
                }
            }

            step = 'fetch_call';
            if (btnElement && type !== 'view') {
                btnElement.style.pointerEvents = 'none';
                btnElement.style.opacity = '0.5';
                btnElement.style.transition = 'opacity 0.2s';
            }
            
            const targetUrl = window.location.origin + '/api/interact';
            const res = await fetch(targetUrl, {
                method: 'POST',
                headers: headers,
                body: JSON.stringify({
                    content_id: window.postId,
                    type: type,
                    user_id: window.currentUserId
                })
            });

            step = 'json_parse';
            const data = await res.json();
            
            step = 'success_check';
            if (btnElement && type !== 'view') {
                btnElement.style.pointerEvents = 'auto';
                btnElement.style.opacity = '1';
            }

            if (data.success && type !== 'view') {
                const likesEl = document.getElementById('likes-count');
                if (likesEl && data.likes !== undefined) {
                    const oldLikes = parseInt(likesEl.innerText);
                    likesEl.innerText = data.likes;
                    if (btnElement) {
                        if (type === 'like') {
                            if (data.likes > oldLikes) {
                                btnElement.classList.add('active');
                                toggleSvgFill(btnElement, true);
                                const dislikeBtn = document.querySelector('.btn-dislike');
                                if (dislikeBtn) { dislikeBtn.classList.remove('active'); toggleSvgFill(dislikeBtn, false); }
                            } else if (data.likes < oldLikes) {
                                btnElement.classList.remove('active');
                                toggleSvgFill(btnElement, false);
                            }
                        } else if (type === 'dislike') {
                            btnElement.classList.toggle('active');
                            toggleSvgFill(btnElement, btnElement.classList.contains('active'));
                            if (btnElement.classList.contains('active')) {
                                const likeBtn = document.querySelector('.btn-like');
                                if (likeBtn) { likeBtn.classList.remove('active'); toggleSvgFill(likeBtn, false); }
                            }
                        }
                    }
                }
            } else if (!data.success && type !== 'view') {
                alert('Помилка лайку: ' + data.error);
            }
        } catch (e) {
            console.error('Interaction error at step ' + step + ':', e);
            if (btnElement && type !== 'view') {
                btnElement.style.pointerEvents = 'auto';
                btnElement.style.opacity = '1';
            }
            if (type !== 'view') {
                alert(`Мережева помилка (крок: ${step}): ` + e.name + ' - ' + e.message);
            }
        }
    };

    function setReply(id, name) {
        replyToId = id;
        editModeId = null;
        const input = document.getElementById('comment-input');
        input.placeholder = `Відповідь для ${name.toUpperCase()}...`;
        input.focus();
    }

    function startEditComment(id) {
        editModeId = id;
        replyToId = null;
        const input = document.getElementById('comment-input');
        const text = document.getElementById(`comment-text-${id}`).innerText;
        input.value = text;
        input.placeholder = 'Редагувати коментар...';
        input.focus();
    }

    async function deleteComment(id) {
        if (!confirm('Видалити коментар?')) return;
        
        const item = document.getElementById('comment-item-' + id);
        if (item) {
            item.style.transition = 'opacity 0.2s';
            item.style.opacity = '0.4';
            item.style.pointerEvents = 'none';
        }
        
        try {
            const res = await fetch(`/api/comments/${id}`, {
                method: 'DELETE',
                headers: { 
                    'Content-Type': 'application/json',
                    'X-Telegram-Init-Data': window.Telegram?.WebApp?.initData || ''
                },
                body: JSON.stringify({ user_id: currentUserId })
            });
            const data = await res.json();
            if (data.success) {
                if (item) {
                    const nestedCount = item.querySelectorAll('.comment-item').length;
                    const totalDeleted = 1 + nestedCount;
                    item.remove();
                    
                    const countEl = document.getElementById('comment-count-number');
                    if (countEl) {
                        countEl.innerText = Math.max(0, parseInt(countEl.innerText) - totalDeleted);
                    }
                }
            } else {
                alert('Помилка: ' + (data.error || 'Не вдалося видалити'));
                if (item) {
                    item.style.opacity = '1';
                    item.style.pointerEvents = 'auto';
                }
            }
        } catch (e) { 
            alert('Помилка мережі');
            if (item) {
                item.style.opacity = '1';
                item.style.pointerEvents = 'auto';
            }
        }
    }

    function appendCommentToDOM(c) {
        const html = `
            <div class="bg-surface border-2 border-border rounded p-4 mb-4 shadow-brutal comment-item" id="comment-item-${c.id}">
                <div class="flex items-center mb-3">
                    <div class="w-10 h-10 rounded bg-surface border-2 border-border shadow-brutal-sm overflow-hidden flex items-center justify-center mr-3 shrink-0"><img src="/avatar/${c.user_id}" loading="lazy" class="w-full h-full object-cover block" /></div>
                    <div>
                        <div class="font-bold text-[15px] text-primary mb-0-5 font-unbounded tracking-tight uppercase">${c.author_name}</div>
                        <div class="text-[12px] text-muted font-bold uppercase">Зараз</div>
                    </div>
                </div>
                <div class="text-[15px] text-primary leading-relaxed font-semibold break-words" id="comment-text-${c.id}">${c.text}</div>
                <div class="flex gap-4 mt-3 items-center flex-wrap">
                    <button class="bg-transparent border-none p-0 text-[13px] font-bold text-muted cursor-pointer flex items-center gap-1 hover:text-primary transition-all font-unbounded uppercase" onclick="setReply(${c.id}, '${c.author_name.replace(/'/g, "\\'")}')"><i data-lucide="corner-down-right" class="w-4 h-4 stroke-2-5"></i> Відповісти</button>
                    <div class="owner-actions flex gap-4 flex-wrap" data-owner-id="${c.user_id}" data-cid="${c.id}">
                        <button class="bg-transparent border-none p-0 text-[13px] font-bold text-primary cursor-pointer flex items-center gap-1 transition-all font-unbounded uppercase edit-btn" onclick="startEditComment(${c.id})"><i data-lucide="edit-2" class="w-4 h-4 stroke-2-5"></i></button>
                        <button class="bg-transparent border-none p-0 text-[13px] font-bold text-danger cursor-pointer flex items-center gap-1 transition-all font-unbounded uppercase delete-btn" onclick="deleteComment(${c.id})"><i data-lucide="trash-2" class="w-4 h-4 stroke-2-5"></i></button>
                    </div>
                </div>
                <div class="comment-reply-wrapper hidden ml-3 border-l-2 border-border pl-3 mt-4" id="replies-${c.id}"></div>
            </div>
        `;
        
        const emptyState = document.querySelector('.empty-state');
        if (emptyState) emptyState.remove();

        if (c.parent_id) {
            const parentWrapper = document.getElementById(`replies-${c.parent_id}`);
            if (parentWrapper) {
                parentWrapper.style.display = 'block';
                parentWrapper.insertAdjacentHTML('beforeend', html);
            }
        } else {
            const list = document.getElementById('comments-list');
            if (list) {
                list.insertAdjacentHTML('beforeend', html);
            }
        }
        
        if (window.lucide) {
            window.lucide.createIcons();
        }
    }

    async function submitComment(e) {
        e.preventDefault();
        const input = document.getElementById('comment-input');
        const text = input.value.trim();
        if (!text) return;

        try {
            let res;
            if (editModeId) {
                res = await fetch(`/api/comments/${editModeId}`, {
                    method: 'PUT',
                    headers: { 
                        'Content-Type': 'application/json',
                        'X-Telegram-Init-Data': window.Telegram?.WebApp?.initData || ''
                    },
                    body: JSON.stringify({ user_id: currentUserId, text: text })
                });
            } else {
                res = await fetch(`/api/projects/${postId}/comments`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'X-Telegram-Init-Data': window.Telegram?.WebApp?.initData || ''
                    },
                    body: JSON.stringify({
                        user_id: currentUserId,
                        author_name: authorName,
                        text: text,
                        parent_id: replyToId
                    })
                });
            }
            
            const data = await res.json();
            if (data.success) {
                if (editModeId) {
                    document.getElementById(`comment-text-${editModeId}`).innerText = text;
                } else {
                    appendCommentToDOM(data.data);
                    const countEl = document.getElementById('comment-count-number');
                    if (countEl) {
                        countEl.innerText = parseInt(countEl.innerText) + 1;
                    }
                }
                
                input.value = '';
                replyToId = null;
                editModeId = null;
                input.placeholder = 'Написати коментар...';
            } else {
                alert('Помилка: ' + (data.error || 'Не вдалося зберегти'));
            }
        } catch (e) {
            alert('Помилка мережі');
        }
    }
</script>
{% endblock %}

{% block tabbar %}{% endblock %}
