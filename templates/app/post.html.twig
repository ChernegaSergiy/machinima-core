{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
<div class="top-nav">
    <a href="{{ path('app_index') }}" class="back-btn"><i data-lucide="arrow-left"></i> Назад</a>
</div>

<div class="container" style="padding-bottom: 80px;">
    <div class="card" style="margin-top: 16px;">
        <div class="card-header">
            <div class="avatar"><i data-lucide="user"></i></div>
            <div class="author-info">
                <div class="author-name">{% if post.staff|length > 0 %}{{ post.staff|first.author.name }}{% else %}Автор невідомий{% endif %}</div>
                <div class="author-meta">{{ post.type }} • {{ post.createdAt|date('d.m.Y H:i') }}</div>
            </div>
        </div>
        
        <h1 class="post-full-title">{{ post.title }}</h1>
        
        <div class="post-full-desc">
            {{ post.description|nl2br }}
        </div>
        
        <div class="post-media" style="aspect-ratio: auto; min-height: 200px;">
            {% if post.coverFileId %}
                <span style="font-weight:700;">[Кобложка]</span>
            {% else %}
                <i data-lucide="image" style="width:48px; height:48px;"></i>
            {% endif %}
        </div>
        
        <div class="post-actions">
            <div class="action-item"><i data-lucide="heart"></i> {{ post.likesCount }}</div>
            <div class="action-item"><i data-lucide="thumbs-down"></i> {{ post.dislikesCount }}</div>
            <div class="action-item ml-auto"><i data-lucide="eye"></i> {{ post.viewsCount }}</div>
        </div>
    </div>

    <script>
        (function() {
            var userId = window.Telegram?.WebApp?.initDataUnsafe?.user?.id || 123456789;
            var isModerator = {{ isModerator ? 'true' : 'false' }};
            var style = document.createElement('style');
            var css = '.owner-actions[data-owner-id="' + userId + '"] { display: flex !important; }';
            
            if (isModerator) {
                css += '\\n.owner-actions { display: flex !important; }';
                css += '\\n.owner-actions:not([data-owner-id="' + userId + '"]) .edit-btn { display: none !important; }';
            }
            
            style.innerHTML = css;
            document.head.appendChild(style);
        })();
    </script>
    <h2 class="comment-section-title">Коментарі (<span id="comment-count-number">{{ commentsCount }}</span>)</h2>
    
    <div id="comments-list">
        {% if commentsCount == 0 %}
            <div class="empty-state">
                <i data-lucide="message-square"></i>
                <div class="empty-state-text">Немає коментарів</div>
            </div>
        {% else %}
            {% macro render_comment_tree(tree) %}
                {% for item in tree %}
                    <div class="comment-item" id="comment-item-{{ item.entity.id }}">
                        <div class="comment-header">
                            <div class="comment-avatar"><img src="{{ path('app_avatar', {userId: item.entity.user.id}) }}" alt="" loading="lazy" /></div>
                            <div>
                                <div class="comment-author">{{ item.entity.authorName }}</div>
                                <div class="comment-date">{{ item.entity.createdAt|date('d.m.Y H:i') }}</div>
                            </div>
                        </div>
                        <div class="comment-text" id="comment-text-{{ item.entity.id }}">{{ item.entity.text }}</div>
                        <div class="comment-actions" style="display: flex; gap: 8px; margin-top: 12px; align-items: center; flex-wrap: wrap;">
                            <button class="reply-btn" onclick="setReply({{ item.entity.id }}, '{{ item.entity.authorName|escape('js') }}')"><i data-lucide="corner-down-right"></i> Відповісти</button>
                            <div class="owner-actions" style="display: none; gap: 8px; flex-wrap: wrap;" data-owner-id="{{ item.entity.user.id }}" data-cid="{{ item.entity.id }}">
                                <button class="reply-btn edit-btn" style="color: var(--text);" onclick="startEditComment({{ item.entity.id }})"><i data-lucide="edit-2"></i></button>
                                <button class="reply-btn delete-btn" style="color: #d32f2f;" onclick="deleteComment({{ item.entity.id }})"><i data-lucide="trash-2"></i></button>
                            </div>
                        </div>
                        
                        <div class="comment-reply-wrapper" id="replies-{{ item.entity.id }}" style="{% if item.children|length == 0 %}display:none;{% endif %} margin-left: 12px; border-left: 2px solid var(--border); padding-left: 12px; margin-top: 16px;">
                            {% if item.children|length > 0 %}
                                {{ _self.render_comment_tree(item.children) }}
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            {% endmacro %}
            
            {{ _self.render_comment_tree(commentTree) }}
        {% endif %}
    </div>
</div>

<div class="comment-bar">
    <form id="comment-form" onsubmit="submitComment(event)" class="comment-form">
        <input id="comment-input" type="text" placeholder="Написати коментар..." class="comment-input" required />
        <button type="submit" class="comment-submit"><i data-lucide="send"></i></button>
    </form>
</div>

<script>
    let currentUserId = window.Telegram?.WebApp?.initDataUnsafe?.user?.id || 123456789;
    let authorName = window.Telegram?.WebApp?.initDataUnsafe?.user?.first_name || 'Користувач';
    const postId = {{ post.id }};
    let replyToId = null;
    let editModeId = null;

    function setReply(id, name) {
        replyToId = id;
        editModeId = null;
        const input = document.getElementById('comment-input');
        input.placeholder = `Відповідь для ${name.toUpperCase()}...`;
        input.focus();
    }

    function startEditComment(id) {
        editModeId = id;
        replyToId = null;
        const input = document.getElementById('comment-input');
        const text = document.getElementById(`comment-text-${id}`).innerText;
        input.value = text;
        input.placeholder = 'Редагувати коментар...';
        input.focus();
    }

    async function deleteComment(id) {
        if (!confirm('Видалити коментар?')) return;
        try {
            const res = await fetch(`/api/comments/${id}`, {
                method: 'DELETE',
                headers: { 
                    'Content-Type': 'application/json',
                    'X-Telegram-Init-Data': window.Telegram?.WebApp?.initData || ''
                },
                body: JSON.stringify({ user_id: currentUserId })
            });
            const data = await res.json();
            if (data.success) {
                const item = document.getElementById('comment-item-' + id);
                if (item) {
                    const nestedCount = item.querySelectorAll('.comment-item').length;
                    const totalDeleted = 1 + nestedCount;
                    item.remove();
                    
                    const countEl = document.getElementById('comment-count-number');
                    if (countEl) {
                        countEl.innerText = Math.max(0, parseInt(countEl.innerText) - totalDeleted);
                    }
                }
            } else {
                alert('Помилка: ' + (data.error || 'Не вдалося видалити'));
            }
        } catch (e) { alert('Помилка мережі'); }
    }

    function appendCommentToDOM(c) {
        const html = `
            <div class="comment-item" id="comment-item-${c.id}">
                <div class="comment-header">
                    <div class="comment-avatar"><img src="/avatar/${c.user_id}" loading="lazy" /></div>
                    <div>
                        <div class="comment-author">${c.author_name}</div>
                        <div class="comment-date">Зараз</div>
                    </div>
                </div>
                <div class="comment-text" id="comment-text-${c.id}">${c.text}</div>
                <div class="comment-actions" style="display: flex; gap: 8px; margin-top: 12px; align-items: center; flex-wrap: wrap;">
                    <button class="reply-btn" onclick="setReply(${c.id}, '${c.author_name.replace(/'/g, "\\'")}')"><i data-lucide="corner-down-right"></i> Відповісти</button>
                    <div class="owner-actions" style="display: flex; gap: 8px; flex-wrap: wrap;" data-owner-id="${c.user_id}" data-cid="${c.id}">
                        <button class="reply-btn edit-btn" style="color: var(--text);" onclick="startEditComment(${c.id})"><i data-lucide="edit-2"></i></button>
                        <button class="reply-btn delete-btn" style="color: #d32f2f;" onclick="deleteComment(${c.id})"><i data-lucide="trash-2"></i></button>
                    </div>
                </div>
                <div class="comment-reply-wrapper" id="replies-${c.id}" style="display:none; margin-left: 12px; border-left: 2px solid var(--border); padding-left: 12px; margin-top: 16px;"></div>
            </div>
        `;
        
        const emptyState = document.querySelector('.empty-state');
        if (emptyState) emptyState.remove();

        if (c.parent_id) {
            const parentWrapper = document.getElementById(`replies-${c.parent_id}`);
            if (parentWrapper) {
                parentWrapper.style.display = 'block';
                parentWrapper.insertAdjacentHTML('beforeend', html);
            }
        } else {
            const list = document.getElementById('comments-list');
            if (list) {
                list.insertAdjacentHTML('beforeend', html);
            }
        }
        
        if (window.lucide) {
            window.lucide.createIcons();
        }
    }

    async function submitComment(e) {
        e.preventDefault();
        const input = document.getElementById('comment-input');
        const text = input.value.trim();
        if (!text) return;

        try {
            let res;
            if (editModeId) {
                res = await fetch(`/api/comments/${editModeId}`, {
                    method: 'PUT',
                    headers: { 
                        'Content-Type': 'application/json',
                        'X-Telegram-Init-Data': window.Telegram?.WebApp?.initData || ''
                    },
                    body: JSON.stringify({ user_id: currentUserId, text: text })
                });
            } else {
                res = await fetch(`/api/projects/${postId}/comments`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'X-Telegram-Init-Data': window.Telegram?.WebApp?.initData || ''
                    },
                    body: JSON.stringify({
                        user_id: currentUserId,
                        author_name: authorName,
                        text: text,
                        parent_id: replyToId
                    })
                });
            }
            
            const data = await res.json();
            if (data.success) {
                if (editModeId) {
                    document.getElementById(`comment-text-${editModeId}`).innerText = text;
                } else {
                    appendCommentToDOM(data.data);
                    const countEl = document.getElementById('comment-count-number');
                    if (countEl) {
                        countEl.innerText = parseInt(countEl.innerText) + 1;
                    }
                }
                
                input.value = '';
                replyToId = null;
                editModeId = null;
                input.placeholder = 'Написати коментар...';
            } else {
                alert('Помилка: ' + (data.error || 'Не вдалося зберегти'));
            }
        } catch (e) {
            alert('Помилка мережі');
        }
    }
</script>
{% endblock %}

{% block tabbar %}{% endblock %}
