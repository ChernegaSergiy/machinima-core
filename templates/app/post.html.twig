{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block tabbar %}{# Hide tabbar on post view #}{% endblock %}

{% block body %}
<div class="post-view-page" style="padding-bottom: 140px;">
    <div class="header-action-bar">
        <a href="{{ path('app_index') }}" class="tma-button">
            <i data-lucide="arrow-left" style="width: 18px; height: 18px;"></i> Назад
        </a>
    </div>

    <div style="pointer-events: none;">
        <div class="post-card tma-card" style="margin: 0px 16px 16px;">
            <div class="post-header">
                <div class="tma-avatar avatar">
                    <i data-lucide="user" style="color: var(--tg-theme-bg-color);"></i>
                </div>
                <div class="post-author-info">
                    <div class="post-author-name">{{ post.title }}</div>
                    <div class="post-time">{{ post.type }} • {{ post.createdAt|date('d.m.Y') }}</div>
                </div>
            </div>
            
            <div class="post-text line-clamp-2">
                {{ post.description }}
            </div>
            
            <div class="tma-media" style="display: flex; align-items: center; justify-content: center; color: #fff; overflow: hidden; position: relative; padding-top: 56.25%;">
                {% if post.url and ('youtube.com' in post.url or 'youtu.be' in post.url) %}
                    {% set video_id = post.url|split('v=')|last|split('&')|first %}
                    {% if 'youtu.be' in post.url %}
                        {% set video_id = post.url|split('/')|last|split('?')|first %}
                    {% endif %}
                    <iframe style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; " src="https://www.youtube.com/embed/{{ video_id }}" allowfullscreen></iframe>
                {% elseif post.url %}
                    <a href="{{ post.url }}" target="_blank" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #fff; text-decoration: none;">
                        <i data-lucide="external-link" style="width: 48px; height: 48px; margin-bottom: 8px;"></i>
                        <br>Відкрити відео
                    </a>
                {% elseif post.coverFileId %}
                    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">[Cover Image]</div>
                {% else %}
                    <i data-lucide="image" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 48px; height: 48px;"></i>
                {% endif %}
            </div>
            
            <div class="post-actions" style="margin-top: 12px;">
                <div class="tma-button action-button" onclick="interact('like')">
                    <i data-lucide="heart"></i> <span id="likes-count">{{ post.likesCount }}</span>
                </div>
                <div class="tma-button action-button" onclick="interact('dislike')">
                    <i data-lucide="thumbs-down"></i> <span id="dislikes-count">{{ post.dislikesCount }}</span>
                </div>
                <div class="tma-button action-button">
                    <i data-lucide="eye"></i> <span id="views-count">{{ post.viewsCount }}</span>
                </div>
            </div>
        </div>
    </div>
    
    <div style="padding: 0 16px;">
        <h3 class="tma-section-header" style="padding: 0 0 8px 0; font-size: 20px;">
            Коментарі ({{ commentsCount }})
        </h3>
        
        {% if commentsCount == 0 %}
            <div style="padding: 24px; text-align: center; font-weight: 600;">
                Ще немає коментарів. Будьте першим!
            </div>
        {% else %}
            {% macro render_comment(node, depth) %}
                {% import _self as macros %}
                {% set comment = node.entity %}
                <div style="margin-top: {% if depth == 0 %}16px{% else %}8px{% endif %}; margin-left: {% if depth > 0 %}24px{% else %}0{% endif %}; border-left: {% if depth > 0 %}2px solid var(--eh-border){% else %}none{% endif %}; padding-left: {% if depth > 0 %}16px{% else %}0{% endif %};">
                    <div class="comment-box">
                        <div style="display: flex; align-items: center; margin-bottom: 8px; padding-bottom: 8px;">
                            <div class="tma-avatar" style="width: 32px; height: 32px; margin-right: 10px;">
                                <span style="font-size: 14px; ">{{ comment.authorName|first|upper }}</span>
                            </div>
                            <div style="flex: 1;">
                                <div style="font-size: 14px; ">{{ comment.authorName }}</div>
                                <div style="font-size: 11px; color: var(--tg-theme-hint-color); font-weight: 600;">
                                    {{ comment.createdAt|date('d.m.y H:i') }}
                                </div>
                            </div>
                        </div>
                        <div style="font-size: 15px; font-weight: 500; line-height: 1.4; word-break: break-word; margin-bottom: 12px;">
                            {{ comment.text }}
                        </div>
                        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                            <button class="tma-button" style="padding: 4px 8px; font-size: 12px;" onclick="setReply({{ comment.id }}, '{{ comment.authorName|escape('js') }}')">
                                <i data-lucide="reply" style="width: 14px; height: 14px; margin-right: 4px;"></i> Відповісти
                            </button>
                        </div>
                    </div>
                    {% for child in node.children %}
                        {{ macros.render_comment(child, depth + 1) }}
                    {% endfor %}
                </div>
            {% endmacro %}
            
            {% import _self as recursive %}
            <div>
                {% for node in commentTree %}
                    {{ recursive.render_comment(node, 0) }}
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <!-- Sticky form -->
    <div class="comment-input-area">
        <form id="comment-form" onsubmit="submitComment(event)" style="display: flex; gap: 12px; width: 100%;">
                <input id="comment-input" type="text" placeholder="Написати коментар..." style="flex: 1; padding: 12px; color: var(--tg-theme-text-color); font-size: 16px; font-family: inherit; outline: none; " />
                <button type="submit" class="tma-button" style="padding: 0 16px; background-color: var(--tg-theme-button-color); color: #fff;">
                    <i data-lucide="send" style="width: 24px; height: 24px;"></i>
                </button>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    const postId = {{ post.id }};
    const tgUser = window.Telegram?.WebApp?.initDataUnsafe?.user;
    const currentUserId = tgUser?.id || 1;
    const authorName = tgUser?.first_name || 'Анонім';
    let replyToId = null;

    function interact(type) {
        if (window.Telegram?.WebApp?.HapticFeedback) {
            window.Telegram.WebApp.HapticFeedback.impactOccurred('light');
        }
        fetch('/api/interact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                content_id: postId,
                user_id: currentUserId,
                type: type
            })
        }).catch(err => console.error(err));
    }

    function submitComment(e) {
        e.preventDefault();
        const input = document.getElementById('comment-input');
        const text = input.value.trim();
        if (!text) return;

        fetch(`/api/projects/${postId}/comments`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                user_id: currentUserId,
                author_name: authorName,
                text: text,
                parent_id: replyToId
            })
        }).then(res => res.json()).then(data => {
            if(data.success) {
                input.value = '';
                replyToId = null;
                input.placeholder = 'Написати коментар...';
                // Reload to display the new comment immediately
                window.location.reload();
            }
        });
    }

    function setReply(id, name) {
        replyToId = id;
        const input = document.getElementById('comment-input');
        input.placeholder = `Відповідь для ${name.toUpperCase()}...`;
        input.focus();
    }

    // Listen to Mercure events for real-time updates without polling
    try {
        const mercureUrl = new URL('/.well-known/mercure', window.location.origin);
        mercureUrl.searchParams.append('topic', 'machinima/updates');
        
        const eventSource = new EventSource(mercureUrl.href);
        eventSource.onmessage = event => {
            const data = JSON.parse(event.data);
            if (data.type === 'STATS_UPDATE' && data.content_id === postId) {
                document.getElementById('likes-count').innerText = data.likes;
                document.getElementById('dislikes-count').innerText = data.dislikes;
                document.getElementById('views-count').innerText = data.views;
            } else if (data.type === 'NEW_COMMENT' && data.content_id === postId) {
                // If another user commented, just reload the page to render the new tree
                window.location.reload();
            }
        };
    } catch (e) {
        console.error('Mercure connection failed', e);
    }
</script>
{% endblock %}
