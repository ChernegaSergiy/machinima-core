{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
<div class="top-nav">
    <a href="{{ path('app_index') }}" class="back-btn"><i data-lucide="arrow-left"></i> Назад</a>
</div>

<div class="container pb-20">
    <div class="card">
        <div class="card-header">
            <div class="avatar"><i data-lucide="user"></i></div>
            <div class="author-info">
                <div class="author-name">{% if post.staff|length > 0 %}{{ post.staff|first.author.name }}{% else %}Автор невідомий{% endif %}</div>
                <div class="author-meta">{{ post.type }} • <time class="local-time" datetime="{{ post.createdAt|date('c') }}" data-format="datetime">{{ post.createdAt|date('d.m.Y H:i') }}</time></div>
            </div>
        </div>
        
        <h1 class="post-full-title">{{ post.title }}</h1>
        
        <div class="post-full-desc">
            {{ post.description|nl2br }}
        </div>
        
        <div class="post-media">
            {% if post.coverFileId %}
                {% if post.coverFileId starts with 'http' %}
                    <img src="{{ post.coverFileId }}" alt="Cover" class="w-full h-full object-cover block" />
                {% else %}
                    <img src="{{ path('app_media', {fileId: post.coverFileId}) }}" alt="Cover" class="w-full h-full object-cover block" />
                {% endif %}
            {% else %}
                <i data-lucide="image" class="w-12 h-12"></i>
            {% endif %}
        </div>
        
        <div class="post-actions" data-post-id="{{ post.id }}">
            <div class="action-item btn-like cursor-pointer" onclick="interact('like', this)"><i data-lucide="heart"></i> <span id="likes-count">{{ post.likesCount }}</span></div>
            <div class="action-item btn-dislike cursor-pointer" onclick="interact('dislike', this)"><i data-lucide="thumbs-down"></i></div>
            <div class="action-item ml-auto"><i data-lucide="eye"></i> <span id="views-count">{{ post.viewsCount }}</span></div>
        </div>
    </div>

    {% if post.staff|length > 0 %}
    <h2 class="section-title">Команда проєкту</h2>
    <div class="mb-6">
        {% for staffItem in post.staff %}
            <div class="list-item">
                <div class="list-icon">
                    <i data-lucide="user"></i>
                </div>
                <div class="list-content">
                    <h3 class="list-title">{{ staffItem.author.name }}</h3>
                    <div class="list-desc">{{ staffItem.role }}</div>
                </div>
            </div>
        {% endfor %}
    </div>
    {% endif %}

    <script>
        (function() {
            var userId = window.Telegram?.WebApp?.initDataUnsafe?.user?.id;
            var tgData = window.Telegram?.WebApp?.initData;
            
            // Apply owner-specific CSS immediately
            var style = document.createElement('style');
            var css = '.owner-actions[data-owner-id="' + userId + '"] { display: flex !important; }';
            
            // Verify moderator status asynchronously to bypass cache
            if (tgData) {
                fetch('/api/me', {
                    headers: { 'X-Telegram-Init-Data': tgData }
                })
                .then(r => r.json())
                .then(data => {
                    if (data.is_moderator) {
                        css += '\n.owner-actions { display: flex !important; }';
                        css += '\n.owner-actions:not([data-owner-id="' + userId + '"]) .edit-btn { display: none !important; }';
                        style.innerHTML = css;
                    }
                })
                .catch(e => console.error('Failed to verify moderator status:', e));
            }

            style.innerHTML = css;
            document.head.appendChild(style);
        })();
    </script>
    <h2 class="comment-section-title">Коментарі (<span id="comment-count-number">{{ commentsCount }}</span>)</h2>
    
    <div id="comments-list">
        {% if commentsCount == 0 %}
            <div class="empty-state">
                <i data-lucide="message-square"></i>
                <div class="empty-state-text">Немає коментарів</div>
            </div>
        {% else %}
            {% macro render_comment_tree(tree) %}
                {% for item in tree %}
                    <div class="comment-item" id="comment-item-{{ item.entity.id }}">
                        <div class="comment-header">
                            <div class="comment-avatar"><img src="{{ path('app_avatar', {userId: item.entity.user.id}) }}" alt="" loading="lazy" /></div>
                            <div>
                                <div class="comment-author">{{ item.entity.authorName }}</div>
                                <div class="comment-date"><time class="local-time" datetime="{{ item.entity.createdAt|date('c') }}" data-format="datetime">{{ item.entity.createdAt|date('d.m.Y H:i') }}</time></div>
                            </div>
                        </div>
                        <div class="comment-text" id="comment-text-{{ item.entity.id }}">{{ item.entity.text }}</div>
                        <div class="comment-actions flex gap-2 mt-3 items-center flex-wrap">
                            <button class="reply-btn" onclick="setReply({{ item.entity.id }}, '{{ item.entity.authorName|escape('js') }}')"><i data-lucide="corner-down-right"></i> Відповісти</button>
                            <div class="owner-actions hidden gap-2 flex-wrap" data-owner-id="{{ item.entity.user.id }}" data-cid="{{ item.entity.id }}">
                                <button class="reply-btn edit-btn text-primary" onclick="startEditComment({{ item.entity.id }})"><i data-lucide="edit-2"></i></button>
                                <button class="reply-btn delete-btn text-danger" onclick="deleteComment({{ item.entity.id }})"><i data-lucide="trash-2"></i></button>
                            </div>
                        </div>
                        
                        <div class="comment-reply-wrapper {% if item.children|length == 0 %}hidden{% endif %} ml-3 border-l-2 pl-3 mt-4" id="replies-{{ item.entity.id }}">
                            {% if item.children|length > 0 %}
                                {{ _self.render_comment_tree(item.children) }}
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            {% endmacro %}
            
            {{ _self.render_comment_tree(commentTree) }}
        {% endif %}
    </div>
</div>

<div class="comment-bar">
    <form id="comment-form" onsubmit="submitComment(event)" class="comment-form">
        <input id="comment-input" type="text" placeholder="Написати коментар..." class="comment-input" required />
        <button type="submit" class="comment-submit"><i data-lucide="send"></i></button>
    </form>
</div>

<script>
    window.currentUserId = window.Telegram?.WebApp?.initDataUnsafe?.user?.id;
    window.authorName = window.Telegram?.WebApp?.initDataUnsafe?.user?.first_name || 'Користувач';
    window.postId = {{ post.id }};
    window.replyToId = null;
    window.editModeId = null;

    window.interact = async function(type, btnElement) {
        let step = 'init';
        try {
            step = 'tgData';
            const tgData = window.Telegram?.WebApp?.initData;
            
            step = 'headers';
            const headers = { 'Content-Type': 'application/json' };
            if (tgData && typeof tgData === 'string') {
                const cleaned = tgData.replace(/[^\x20-\x7E]/g, '').trim();
                if (cleaned.length > 0) {
                    headers['X-Telegram-Init-Data'] = cleaned;
                }
            }

            step = 'fetch_call';
            if (btnElement && type !== 'view') {
                btnElement.style.pointerEvents = 'none';
                btnElement.style.opacity = '0.5';
                btnElement.style.transition = 'opacity 0.2s';
            }
            
            const targetUrl = window.location.origin + '/api/interact';
            const res = await fetch(targetUrl, {
                method: 'POST',
                headers: headers,
                body: JSON.stringify({
                    content_id: window.postId,
                    type: type,
                    user_id: window.currentUserId
                })
            });

            step = 'json_parse';
            const data = await res.json();
            
            step = 'success_check';
            if (btnElement && type !== 'view') {
                btnElement.style.pointerEvents = 'auto';
                btnElement.style.opacity = '1';
            }

            if (data.success && type !== 'view') {
                const likesEl = document.getElementById('likes-count');
                if (likesEl && data.likes !== undefined) {
                    const oldLikes = parseInt(likesEl.innerText);
                    likesEl.innerText = data.likes;
                    if (btnElement) {
                        if (type === 'like') {
                            if (data.likes > oldLikes) {
                                btnElement.classList.add('active');
                                const dislikeBtn = document.querySelector('.btn-dislike');
                                if (dislikeBtn) dislikeBtn.classList.remove('active');
                            } else if (data.likes < oldLikes) {
                                btnElement.classList.remove('active');
                            }
                        } else if (type === 'dislike') {
                            btnElement.classList.toggle('active');
                            if (btnElement.classList.contains('active')) {
                                const likeBtn = document.querySelector('.btn-like');
                                if (likeBtn) likeBtn.classList.remove('active');
                            }
                        }
                    }
                }
            } else if (!data.success && type !== 'view') {
                alert('Помилка лайку: ' + data.error);
            }
        } catch (e) {
            console.error('Interaction error at step ' + step + ':', e);
            if (btnElement && type !== 'view') {
                btnElement.style.pointerEvents = 'auto';
                btnElement.style.opacity = '1';
            }
            if (type !== 'view') {
                alert(`Мережева помилка (крок: ${step}): ` + e.name + ' - ' + e.message);
            }
        }
    };

    function setReply(id, name) {
        replyToId = id;
        editModeId = null;
        const input = document.getElementById('comment-input');
        input.placeholder = `Відповідь для ${name.toUpperCase()}...`;
        input.focus();
    }

    function startEditComment(id) {
        editModeId = id;
        replyToId = null;
        const input = document.getElementById('comment-input');
        const text = document.getElementById(`comment-text-${id}`).innerText;
        input.value = text;
        input.placeholder = 'Редагувати коментар...';
        input.focus();
    }

    async function deleteComment(id) {
        if (!confirm('Видалити коментар?')) return;
        
        const item = document.getElementById('comment-item-' + id);
        if (item) {
            item.style.transition = 'opacity 0.2s';
            item.style.opacity = '0.4';
            item.style.pointerEvents = 'none';
        }
        
        try {
            const res = await fetch(`/api/comments/${id}`, {
                method: 'DELETE',
                headers: { 
                    'Content-Type': 'application/json',
                    'X-Telegram-Init-Data': window.Telegram?.WebApp?.initData || ''
                },
                body: JSON.stringify({ user_id: currentUserId })
            });
            const data = await res.json();
            if (data.success) {
                if (item) {
                    const nestedCount = item.querySelectorAll('.comment-item').length;
                    const totalDeleted = 1 + nestedCount;
                    item.remove();
                    
                    const countEl = document.getElementById('comment-count-number');
                    if (countEl) {
                        countEl.innerText = Math.max(0, parseInt(countEl.innerText) - totalDeleted);
                    }
                }
            } else {
                alert('Помилка: ' + (data.error || 'Не вдалося видалити'));
                if (item) {
                    item.style.opacity = '1';
                    item.style.pointerEvents = 'auto';
                }
            }
        } catch (e) { 
            alert('Помилка мережі');
            if (item) {
                item.style.opacity = '1';
                item.style.pointerEvents = 'auto';
            }
        }
    }

    function appendCommentToDOM(c) {
        const html = `
            <div class="comment-item" id="comment-item-${c.id}">
                <div class="comment-header">
                    <div class="comment-avatar"><img src="/avatar/${c.user_id}" loading="lazy" /></div>
                    <div>
                        <div class="comment-author">${c.author_name}</div>
                        <div class="comment-date">Зараз</div>
                    </div>
                </div>
                <div class="comment-text" id="comment-text-${c.id}">${c.text}</div>
                <div class="comment-actions flex gap-2 mt-3 items-center flex-wrap">
                    <button class="reply-btn" onclick="setReply(${c.id}, '${c.author_name.replace(/'/g, "\\'")}')"><i data-lucide="corner-down-right"></i> Відповісти</button>
                    <div class="owner-actions flex gap-2 flex-wrap" data-owner-id="${c.user_id}" data-cid="${c.id}">
                        <button class="reply-btn edit-btn text-primary" onclick="startEditComment(${c.id})"><i data-lucide="edit-2"></i></button>
                        <button class="reply-btn delete-btn text-danger" onclick="deleteComment(${c.id})"><i data-lucide="trash-2"></i></button>
                    </div>
                </div>
                <div class="comment-reply-wrapper hidden ml-3 border-l-2 pl-3 mt-4" id="replies-${c.id}"></div>
            </div>
        `;
        
        const emptyState = document.querySelector('.empty-state');
        if (emptyState) emptyState.remove();

        if (c.parent_id) {
            const parentWrapper = document.getElementById(`replies-${c.parent_id}`);
            if (parentWrapper) {
                parentWrapper.style.display = 'block';
                parentWrapper.insertAdjacentHTML('beforeend', html);
            }
        } else {
            const list = document.getElementById('comments-list');
            if (list) {
                list.insertAdjacentHTML('beforeend', html);
            }
        }
        
        if (window.lucide) {
            window.lucide.createIcons();
        }
    }

    async function submitComment(e) {
        e.preventDefault();
        const input = document.getElementById('comment-input');
        const text = input.value.trim();
        if (!text) return;

        try {
            let res;
            if (editModeId) {
                res = await fetch(`/api/comments/${editModeId}`, {
                    method: 'PUT',
                    headers: { 
                        'Content-Type': 'application/json',
                        'X-Telegram-Init-Data': window.Telegram?.WebApp?.initData || ''
                    },
                    body: JSON.stringify({ user_id: currentUserId, text: text })
                });
            } else {
                res = await fetch(`/api/projects/${postId}/comments`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'X-Telegram-Init-Data': window.Telegram?.WebApp?.initData || ''
                    },
                    body: JSON.stringify({
                        user_id: currentUserId,
                        author_name: authorName,
                        text: text,
                        parent_id: replyToId
                    })
                });
            }
            
            const data = await res.json();
            if (data.success) {
                if (editModeId) {
                    document.getElementById(`comment-text-${editModeId}`).innerText = text;
                } else {
                    appendCommentToDOM(data.data);
                    const countEl = document.getElementById('comment-count-number');
                    if (countEl) {
                        countEl.innerText = parseInt(countEl.innerText) + 1;
                    }
                }
                
                input.value = '';
                replyToId = null;
                editModeId = null;
                input.placeholder = 'Написати коментар...';
            } else {
                alert('Помилка: ' + (data.error || 'Не вдалося зберегти'));
            }
        } catch (e) {
            alert('Помилка мережі');
        }
    }
</script>
{% endblock %}

{% block tabbar %}{% endblock %}
