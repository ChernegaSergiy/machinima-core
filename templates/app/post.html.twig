{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
<div class="top-nav">
    <a href="{{ path('app_index') }}" class="back-btn"><i data-lucide="arrow-left"></i> Назад</a>
</div>

<div class="container" style="padding-bottom: 80px;">
    <div class="card" style="margin-top: 16px;">
        <div class="card-header">
            <div class="avatar"><i data-lucide="user"></i></div>
            <div class="author-info">
                <div class="author-name">{% if post.staff|length > 0 %}{{ post.staff|first.author.name }}{% else %}Автор невідомий{% endif %}</div>
                <div class="author-meta">{{ post.type }} • {{ post.createdAt|date('d.m.Y H:i') }}</div>
            </div>
        </div>
        
        <h1 class="post-full-title">{{ post.title }}</h1>
        
        <div class="post-full-desc">
            {{ post.description|nl2br }}
        </div>
        
        <div class="post-media" style="aspect-ratio: auto; min-height: 200px;">
            {% if post.coverFileId %}
                <span style="font-weight:700;">[Кобложка]</span>
            {% else %}
                <i data-lucide="image" style="width:48px; height:48px;"></i>
            {% endif %}
        </div>
        
        <div class="post-actions">
            <div class="action-item"><i data-lucide="heart"></i> {{ post.likesCount }}</div>
            <div class="action-item"><i data-lucide="thumbs-down"></i> {{ post.dislikesCount }}</div>
            <div class="action-item ml-auto"><i data-lucide="eye"></i> {{ post.viewsCount }}</div>
        </div>
    </div>

    <h2 class="comment-section-title">Коментарі ({{ commentsCount }})</h2>
    
    {% if commentsCount == 0 %}
        <div class="empty-state">
            <i data-lucide="message-square"></i>
            <div class="empty-state-text">Немає коментарів</div>
        </div>
    {% else %}
        {% macro render_comment_tree(tree) %}
            {% for item in tree %}
                <div class="comment-item">
                    <div class="comment-header">
                        <div class="comment-avatar"><i data-lucide="user" style="width:16px;height:16px;"></i></div>
                        <div>
                            <div class="comment-author">Користувач {{ item.entity.user.id }}</div>
                            <div class="comment-date">{{ item.entity.createdAt|date('d.m.Y H:i') }}</div>
                        </div>
                    </div>
                    <div class="comment-text">{{ item.entity.text }}</div>
                    <button class="reply-btn"><i data-lucide="corner-down-right"></i> Відповісти</button>
                    
                    {% if item.children|length > 0 %}
                        <div class="comment-reply-wrapper">
                            {{ _self.render_comment_tree(item.children) }}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        {% endmacro %}
        {{ _self.render_comment_tree(commentTree) }}
    {% endif %}
</div>

<div class="comment-bar">
    <form id="comment-form" onsubmit="submitComment(event)" class="comment-form">
        <input id="comment-input" type="text" placeholder="Написати коментар..." class="comment-input" required />
        <button type="submit" class="comment-submit"><i data-lucide="send"></i></button>
    </form>
</div>

<script>
    function submitComment(e) {
        e.preventDefault();
        const input = document.getElementById('comment-input');
        if(input.value.trim() !== '') {
            alert('Функція коментування в розробці (через TMA)');
            input.value = '';
        }
    }
</script>
{% endblock %}
